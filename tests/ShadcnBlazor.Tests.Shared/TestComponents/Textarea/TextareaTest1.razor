@namespace ShadcnBlazor.Tests.Shared.TestComponents.Textarea

<div class="flex flex-col gap-6">
    <div>
        <p class="text-xs text-muted-foreground mb-2">Rows.2 (compact)</p>
        <Textarea Rows="2" Placeholder="Two rows..." />
    </div>

    <div>
        <p class="text-xs text-muted-foreground mb-2">Rows.4 (medium)</p>
        <Textarea Rows="4" Placeholder="Four rows..." />
    </div>

    <div>
        <p class="text-xs text-muted-foreground mb-2">Rows.8 (spacious)</p>
        <Textarea Rows="8" Placeholder="Eight rows..." />
    </div>

    <div>
        <p class="text-xs text-muted-foreground mb-2">All sizes with Rows.4</p>
        <div class="flex flex-col gap-3">
            <div>
                <p class="text-xs text-muted-foreground mb-1">Size.Sm</p>
                <Textarea Rows="4" Size="Size.Sm" Placeholder="Small..." />
            </div>
            <div>
                <p class="text-xs text-muted-foreground mb-1">Size.Md</p>
                <Textarea Rows="4" Size="Size.Md" Placeholder="Medium..." />
            </div>
            <div>
                <p class="text-xs text-muted-foreground mb-1">Size.Lg</p>
                <Textarea Rows="4" Size="Size.Lg" Placeholder="Large..." />
            </div>
        </div>
    </div>
</div>
