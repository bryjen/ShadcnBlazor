@namespace ShadcnBlazor.Tests.Shared.TestComponents.Select

<div class="flex flex-col gap-6 max-w-md">
    <p class="text-xs text-muted-foreground mb-2">Select with grouped items and disabled options</p>

    <div class="relative">
        <button @onclick="@(() => _open = !_open)" class="w-full px-3 py-2 rounded border border-input bg-background text-foreground flex justify-between items-center">
            <span>@(_selectedValue ?? "Choose a fruit...")</span>
            <svg class="w-4 h-4 @(_open ? "rotate-180" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 14-7-7-7 7"></path>
            </svg>
        </button>

        @if (_open)
        {
            <div class="absolute top-full left-0 right-0 mt-1 border border-input rounded bg-popover shadow-lg z-10">
                <div class="p-2">
                    <p class="text-xs font-semibold text-muted-foreground px-2 py-1 uppercase">Fruits</p>
                    @foreach (var item in new[] { "Apple", "Banana", "Orange" })
                    {
                        <button @onclick="@(() => SelectOption(item))"
                               class="w-full text-left px-3 py-2 hover:bg-accent @(_selectedValue == item ? "bg-accent" : "")">
                            @item
                        </button>
                    }
                </div>

                <div class="border-t border-border p-2">
                    <p class="text-xs font-semibold text-muted-foreground px-2 py-1 uppercase">Vegetables</p>
                    @foreach (var item in new[] { "Carrot", "Tomato" })
                    {
                        <button @onclick="@(() => SelectOption(item))"
                               class="w-full text-left px-3 py-2 hover:bg-accent @(_selectedValue == item ? "bg-accent" : "")">
                            @item
                        </button>
                    }
                    <button disabled class="w-full text-left px-3 py-2 text-muted-foreground opacity-50 cursor-not-allowed">
                        Broccoli (disabled)
                    </button>
                </div>
            </div>
        }
    </div>

    <p class="text-sm text-muted-foreground">Selected: <strong>@(_selectedValue ?? "None")</strong></p>
</div>

@code {
    private bool _open;
    private string? _selectedValue;

    private void SelectOption(string value)
    {
        _selectedValue = value;
        _open = false;
    }
}
