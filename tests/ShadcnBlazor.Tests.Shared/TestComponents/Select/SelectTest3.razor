@namespace ShadcnBlazor.Tests.Shared.TestComponents.Select

<div class="flex flex-col gap-4 max-w-sm">
    <p class="text-xs text-muted-foreground mb-2">Select with different sizes</p>

    <div>
        <p class="text-xs text-muted-foreground mb-1">Size: Small</p>
        <select class="w-full px-2 py-1 text-sm rounded border border-input">
            <option>Small select</option>
            <option>Option 2</option>
        </select>
    </div>

    <div>
        <p class="text-xs text-muted-foreground mb-1">Size: Medium (default)</p>
        <select class="w-full px-3 py-2 rounded border border-input">
            <option>Medium select</option>
            <option>Option 2</option>
        </select>
    </div>

    <div>
        <p class="text-xs text-muted-foreground mb-1">Size: Large</p>
        <select class="w-full px-4 py-3 text-lg rounded border border-input">
            <option>Large select</option>
            <option>Option 2</option>
        </select>
    </div>

    <div>
        <p class="text-xs text-muted-foreground mb-1">Disabled state</p>
        <select class="w-full px-3 py-2 rounded border border-input opacity-50 cursor-not-allowed" disabled>
            <option>Disabled select</option>
            <option>Cannot select</option>
        </select>
    </div>
</div>
