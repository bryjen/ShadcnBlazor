@namespace ShadcnBlazor.Tests.Shared.TestComponents.Tabs

<div class="w-full max-w-md">
    <p class="text-xs text-muted-foreground mb-3">Tabs with icons and varied content</p>
    <Tabs Value="@_selectedTab" ValueChanged="OnTabChanged">
        <TabsList>
            <TabsTrigger Value="code">
                <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z"></path>
                </svg>
                Code
            </TabsTrigger>
            <TabsTrigger Value="preview">
                <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path>
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"></path>
                </svg>
                Preview
            </TabsTrigger>
            <TabsTrigger Value="docs">
                <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path>
                    <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 1 1 0 000-2H2a1 1 0 00-1 1v14a1 1 0 001 1h14a1 1 0 001-1V4a1 1 0 00-1-1h-4.586A2 2 0 008 2.414L6.707.293A1 1 0 005.293.293L4 1.586A2 2 0 012 5v9a1 1 0 102 0V5z" clip-rule="evenodd"></path>
                </svg>
                Docs
            </TabsTrigger>
        </TabsList>

        <TabsContent Value="code">
            <div class="p-4 bg-muted rounded">
                <code class="text-sm">
                    &lt;Button&gt;Click me&lt;/Button&gt;
                </code>
            </div>
        </TabsContent>

        <TabsContent Value="preview">
            <div class="p-4">
                <p class="font-semibold mb-2">Component Preview</p>
                <TempButton>Click me</TempButton>
            </div>
        </TabsContent>

        <TabsContent Value="docs">
            <div class="p-4">
                <p class="font-semibold mb-2">Documentation</p>
                <p class="text-sm text-muted-foreground">
                    The Button component is a foundational component for user interactions.
                </p>
            </div>
        </TabsContent>
    </Tabs>
</div>

@code {
    private string _selectedTab = "code";

    private Task OnTabChanged(string value)
    {
        _selectedTab = value;
        return Task.CompletedTask;
    }
}
