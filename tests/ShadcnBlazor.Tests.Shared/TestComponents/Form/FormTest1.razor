@namespace ShadcnBlazor.Tests.Shared.TestComponents.Form

<div class="flex max-w-sm flex-col gap-4">
    <p class="text-xs text-muted-foreground">FormValidationProvider wiring for invalid-state accessibility attributes.</p>

    <FormValidationProvider Invalid="@_invalid" ErrorMessageId="form-email-error">
        <div class="flex flex-col gap-2">
            <label for="email" class="text-sm font-medium">Email</label>
            <Input id="email" @bind-Value="_email" Placeholder="you@example.com" />
            <span id="form-email-error" class="text-sm text-destructive" aria-live="polite">
                @(_invalid ? "Provide a valid email address." : null)
            </span>
        </div>

        <div class="mt-4 flex gap-2">
            <Button OnClick="Validate">Validate</Button>
            <Button Variant="Variant.Outline" OnClick="ToggleInvalid">Toggle invalid</Button>
        </div>
    </FormValidationProvider>
</div>

@code {
    private string _email = string.Empty;
    private bool _invalid;

    private void Validate()
    {
        _invalid = string.IsNullOrWhiteSpace(_email) || !_email.Contains('@');
    }

    private void ToggleInvalid()
    {
        _invalid = !_invalid;
    }
}
