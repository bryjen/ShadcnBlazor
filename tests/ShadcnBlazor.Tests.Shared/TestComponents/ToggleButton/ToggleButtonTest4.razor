@namespace ShadcnBlazor.Tests.Shared.TestComponents.ToggleButton

<div class="flex flex-col gap-6">
    <div>
        <p class="text-xs text-muted-foreground mb-2">PressedChanged callback</p>
        <ToggleButton Pressed="@_pressed" PressedChanged="OnPressedChanged">Toggle with callback</ToggleButton>
        <p class="text-sm text-muted-foreground mt-2">Last event: @_eventLog</p>
    </div>

    <div>
        <p class="text-xs text-muted-foreground mb-2">Disabled toggle button guard (callback should NOT fire)</p>
        <div class="flex gap-8">
            <div>
                <ToggleButton Pressed="@_enabledPressed" PressedChanged="OnEnabledPressed">Enabled</ToggleButton>
                <p class="text-sm mt-2">Fired: @_enabledCount</p>
            </div>
            <div>
                <ToggleButton Disabled="true" Pressed="@_disabledPressed" PressedChanged="OnDisabledPressed">Disabled</ToggleButton>
                <p class="text-sm mt-2">Fired: @_disabledCount (should stay 0)</p>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _pressed;
    private string _eventLog = "none";
    private Task OnPressedChanged(bool val)
    {
        _pressed = val;
        _eventLog = $"{DateTime.Now:HH:mm:ss.fff} → {(val ? "pressed" : "unpressed")}";
        return Task.CompletedTask;
    }

    private bool _enabledPressed;
    private bool _disabledPressed;
    private int _enabledCount;
    private int _disabledCount;

    private Task OnEnabledPressed(bool val)
    {
        _enabledPressed = val;
        _enabledCount++;
        return Task.CompletedTask;
    }

    private Task OnDisabledPressed(bool val)
    {
        _disabledPressed = val;
        _disabledCount++;
        return Task.CompletedTask;
    }
}
