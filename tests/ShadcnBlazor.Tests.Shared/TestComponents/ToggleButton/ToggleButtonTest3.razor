@namespace ShadcnBlazor.Tests.Shared.TestComponents.ToggleButton

<div class="flex flex-col gap-6">
    <div>
        <p class="text-xs text-muted-foreground mb-2">Standalone toggle button (independent press/unpress)</p>
        <ToggleButton>Click me independently</ToggleButton>
    </div>

    <div>
        <p class="text-xs text-muted-foreground mb-2">Group of toggle buttons</p>
        <div class="flex gap-2">
            <ToggleButton Variant="Variant.Outline">Option A</ToggleButton>
            <ToggleButton Variant="Variant.Outline">Option B</ToggleButton>
            <ToggleButton Variant="Variant.Outline">Option C</ToggleButton>
        </div>
        <p class="text-xs text-muted-foreground mt-3">↑ These can all be pressed independently (unlike radio buttons)</p>
    </div>
</div>
