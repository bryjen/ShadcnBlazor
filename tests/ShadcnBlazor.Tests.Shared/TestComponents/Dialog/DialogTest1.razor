@namespace ShadcnBlazor.Tests.Shared.TestComponents.Dialog

<div class="flex flex-col gap-6">
    <p class="text-xs text-muted-foreground mb-2">Click button to open dialog</p>

    <TempButton @onclick="OpenDialog">Open Dialog</TempButton>

    @if (_showDialog)
    {
        <div class="fixed inset-0 bg-black/50 flex items-center justify-center z-50" @onclick="CloseDialog">
            <div class="bg-background rounded-lg shadow-lg p-6 max-w-md w-full mx-4" @onclick:stopPropagation>
                <div class="flex justify-between items-start mb-4">
                    <div>
                        <h2 class="text-lg font-semibold">Dialog Title</h2>
                        <p class="text-sm text-muted-foreground mt-1">This is a simple dialog with a title and description.</p>
                    </div>
                    <button @onclick="CloseDialog" class="text-muted-foreground hover:text-foreground">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>

                <div class="mb-6">
                    <p class="text-sm text-foreground">
                        This dialog demonstrates basic title, description, and action buttons.
                    </p>
                </div>

                <div class="flex gap-3 justify-end">
                    <TempButton Variant="Variant.Outline" @onclick="CloseDialog">Cancel</TempButton>
                    <TempButton @onclick="CloseDialog">Confirm</TempButton>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _showDialog;

    private void OpenDialog()
    {
        _showDialog = true;
    }

    private void CloseDialog()
    {
        _showDialog = false;
    }
}
