@namespace ShadcnBlazor.Tests.Shared.TestComponents.ContextMenu

<div class="flex flex-col gap-4">
    <p class="text-xs text-muted-foreground">Right-click the panel to toggle columns and switch the active environment.</p>

    <ContextMenu>
        <ContextMenuTrigger>
            <div class="rounded-lg border border-border bg-background p-6 shadow-sm">
                <p class="text-sm font-medium">Operations board</p>
                <p class="text-sm text-muted-foreground">Context menu includes checkboxes, radio items, and disabled entries.</p>
            </div>
        </ContextMenuTrigger>
        <ContextMenuContent>
            <ContextMenuLabel>Visible fields</ContextMenuLabel>
            <ContextMenuCheckboxItem Checked="@_showLatency" CheckedChanged="OnShowLatencyChanged">Latency</ContextMenuCheckboxItem>
            <ContextMenuCheckboxItem Checked="@_showErrors" CheckedChanged="OnShowErrorsChanged">Errors</ContextMenuCheckboxItem>
            <ContextMenuSeparator />
            <ContextMenuLabel>Environment</ContextMenuLabel>
            <ContextMenuRadioGroup Value="@_environment" ValueChanged="OnEnvironmentChanged">
                <ContextMenuRadioItem Value="Production">Production</ContextMenuRadioItem>
                <ContextMenuRadioItem Value="Staging">Staging</ContextMenuRadioItem>
                <ContextMenuRadioItem Value="Development">Development</ContextMenuRadioItem>
            </ContextMenuRadioGroup>
            <ContextMenuSeparator />
            <ContextMenuItem Disabled="true">Restricted action</ContextMenuItem>
        </ContextMenuContent>
    </ContextMenu>

    <div class="rounded-md border border-border bg-muted/30 p-3 text-sm">
        <p>Latency column: <span class="font-medium">@(_showLatency ? "Shown" : "Hidden")</span></p>
        <p>Error column: <span class="font-medium">@(_showErrors ? "Shown" : "Hidden")</span></p>
        <p>Environment: <span class="font-medium">@_environment</span></p>
    </div>
</div>

@code {
    private bool _showLatency = true;
    private bool _showErrors = false;
    private string _environment = "Production";

    private Task OnShowLatencyChanged(bool value)
    {
        _showLatency = value;
        return Task.CompletedTask;
    }

    private Task OnShowErrorsChanged(bool value)
    {
        _showErrors = value;
        return Task.CompletedTask;
    }

    private Task OnEnvironmentChanged(string value)
    {
        _environment = value;
        return Task.CompletedTask;
    }
}
