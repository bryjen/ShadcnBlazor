@namespace ShadcnBlazor.Tests.Shared.TestComponents.Slider

<div class="flex flex-col gap-6 max-w-sm">
    <div>
        <p class="text-xs text-muted-foreground mb-2">Size.Sm</p>
        <Slider Size="Size.Sm" Min="0" Max="100" Step="1" Values="@(new List<double> {30, 70})" />
    </div>

    <div>
        <p class="text-xs text-muted-foreground mb-2">Size.Md (default)</p>
        <Slider Size="Size.Md" Min="0" Max="100" Step="1" Values="@(new List<double> {30, 70})" />
    </div>

    <div>
        <p class="text-xs text-muted-foreground mb-2">Size.Lg</p>
        <Slider Size="Size.Lg" Min="0" Max="100" Step="1" Values="@(new List<double> {30, 70})" />
    </div>

    <div>
        <p class="text-xs text-muted-foreground mb-2">Custom range (price selector: $0-$1000)</p>
        <Slider Min="0" Max="1000" Step="10" @bind-Values="_priceRange" />
        <p class="text-sm text-muted-foreground mt-2">Price range: $@_priceRange[0] - $@_priceRange[1]</p>
    </div>

    <div>
        <p class="text-xs text-muted-foreground mb-2">Disabled range slider</p>
        <Slider Min="0" Max="100" Step="1" Values="@(new List<double> {25, 75})" Disabled="true" />
        <p class="text-sm text-muted-foreground mt-1">Both thumbs locked</p>
    </div>
</div>

@code {
    private List<double> _priceRange = new List<double> { 250, 750 };
}
