@namespace ShadcnBlazor.Tests.Shared.TestComponents.Slider

<div class="flex flex-col gap-6 max-w-sm">
    <div>
        <p class="text-xs text-muted-foreground mb-2">Basic slider (0-100, default middle value)</p>
        <Slider Min="0" Max="100" Step="1" Value="50" />
        <p class="text-sm text-muted-foreground mt-2">Value: 50</p>
    </div>

    <div>
        <p class="text-xs text-muted-foreground mb-2">Slider interactive</p>
        <Slider Min="0" Max="100" Step="1" Value="@_value" />
        <p class="text-sm text-muted-foreground mt-2">Current value: @_value</p>
    </div>
</div>

@code {
    private int _value = 50;
}
