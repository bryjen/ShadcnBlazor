@namespace ShadcnBlazor.Tests.Shared.TestComponents.Slider

<div class="flex flex-col gap-6 max-w-sm">
    <div>
        <p class="text-xs text-muted-foreground mb-2">Basic range slider (0-100)</p>
        <RangeSlider Min="0" Max="100" Step="1" LowerValue="20" UpperValue="80" />
        <p class="text-sm text-muted-foreground mt-3">Selected range: 20 - 80</p>
    </div>

    <div>
        <p class="text-xs text-muted-foreground mb-2">Interactive range slider</p>
        <RangeSlider Min="0" Max="100" Step="1" LowerValue="@_lowerValue" UpperValue="@_upperValue" />
        <p class="text-sm text-muted-foreground mt-3">Range: @_lowerValue - @_upperValue</p>
    </div>
</div>

@code {
    private int _lowerValue = 25;
    private int _upperValue = 75;
}
