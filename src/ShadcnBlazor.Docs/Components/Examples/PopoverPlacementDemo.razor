@using ShadcnBlazor.Components.Button

<Popover @bind-Open="_open" AnchorOrigin="@Placement" TransformOrigin="@Placement">
    <Anchor>
        <Button Variant="Variant.Outline" Size="Size.Sm" OnClick="Toggle" class="w-full">
            @DisplayName
        </Button>
    </Anchor>
    <ChildContent>
        <div class="p-3 bg-popover text-popover-foreground rounded-md border shadow-md min-w-[120px]">
            <p class="font-mono text-[10px] text-muted-foreground uppercase tracking-widest mb-1">@Placement</p>
            <p class="text-xs font-medium">Popover at @DisplayName</p>
        </div>
    </ChildContent>
</Popover>

@code {
    private bool _open;

    [Parameter]
    public required PopoverPlacement Placement { get; set; }

    [Parameter]
    public required string DisplayName { get; set; }

    private void Toggle() => _open = !_open;
}
