@using ShadcnBlazor.Components.Popover
@using ShadcnBlazor.Components.Popover.Models

<div class="border border-slate-200 rounded-lg p-4 bg-slate-50">
    <div class="flex items-center justify-between">
        <div>
            <p class="font-semibold text-sm">@Label</p>
            <p class="text-xs text-slate-600 mt-1">Gap between popover and anchor element</p>
        </div>
        <Popover @bind-Open="_open" AnchorOrigin="PopoverPlacement.BottomCenter" Offset="@Offset">
            <Anchor>
                <button class="px-4 py-2 text-sm bg-purple-500 text-white rounded hover:bg-purple-600" @onclick="Toggle">
                    @Label
                </button>
            </Anchor>
            <ChildContent>
                <div class="p-3 bg-white rounded shadow-lg border border-slate-200 text-sm space-y-2">
                    <p class="font-semibold text-slate-900">Offset: @Offset px</p>
                    <p class="text-slate-700 text-xs">Notice the spacing between this popover and the button above.</p>
                    <div class="pt-2 border-t border-slate-200 text-xs text-slate-600">
                        Current offset: <span class="font-mono">@Offset</span>
                    </div>
                </div>
            </ChildContent>
        </Popover>
    </div>
</div>

@code {
    private bool _open;

    [Parameter]
    public required int Offset { get; set; }

    [Parameter]
    public required string Label { get; set; }

    private void Toggle() => _open = !_open;
}
