@using ShadcnBlazor.Components.Button

<div class="border rounded-lg p-4 bg-card text-card-foreground shadow-sm">
    <div class="flex items-center justify-between gap-4">
        <div>
            <p class="text-sm font-semibold">@DisplayName</p>
            <p class="text-xs text-muted-foreground mt-1">Secondary alignment offset.</p>
        </div>
        <Popover @bind-Open="_open" AnchorOrigin="PopoverPlacement.BottomCenter" Offset="8" AlignOffset="@AlignOffset">
            <Anchor>
                <Button Variant="Variant.Outline" Size="Size.Sm" OnClick="Toggle">
                    Try Offset
                </Button>
            </Anchor>
            <ChildContent>
                <div class="p-3 bg-popover text-popover-foreground rounded-md border shadow-lg text-sm">
                    <p class="font-semibold">AlignOffset: @AlignOffset px</p>
                </div>
            </ChildContent>
        </Popover>
    </div>
</div>

@code {
    private bool _open;

    [Parameter] public required string DisplayName { get; set; }
    [Parameter] public int AlignOffset { get; set; }

    private void Toggle() => _open = !_open;
}
