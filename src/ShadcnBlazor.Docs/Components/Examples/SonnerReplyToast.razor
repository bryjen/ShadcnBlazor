@namespace ShadcnBlazor.Docs.Components.Examples

<div class="flex items-start gap-3">
    <div class="h-9 w-9 rounded-full bg-slate-900 text-white flex items-center justify-center text-xs font-semibold">
        SB
    </div>
    <div class="space-y-2">
        <div>
            <div class="text-sm font-semibold text-slate-900">New message</div>
            <div class="text-sm text-slate-600">You have a new reply in "Vaul Sync".</div>
        </div>
        <div class="flex items-center gap-2">
            <button
                class="px-3 py-1.5 rounded-md bg-slate-900 text-white text-xs font-semibold"
                @onclick="OnReply">
                Reply
            </button>
            <button
                class="px-3 py-1.5 rounded-md border border-slate-200 text-xs font-semibold text-slate-700"
                @onclick="OnDismiss">
                Dismiss
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnReply { get; set; }
    [Parameter] public EventCallback OnDismiss { get; set; }
}
