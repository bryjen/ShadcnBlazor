@using EasyAppDev.Blazor.Icons.Lucide

@inherits ShadcnComponentBase

<div class="@(MergeCss("w-full rounded-lg overflow-hidden border border-border", Class))">
    <div class="flex items-center justify-between px-3 py-1 border-b border-border bg-card">
        <div class="flex items-center gap-2 text-muted-foreground">
            <span aria-hidden="true">
                <LuTerminal class="size-3.5" />
            </span>
            <span class="text-xs tracking-wide">Terminal</span>
        </div>
        <Button Size="@Size.Sm"
                Variant="@Variant.Ghost"
                Class="h-7 w-7 p-0 text-muted-foreground hover:text-foreground transition-colors duration-200"
                OnClick="CopyCommandAsync"
                title="@(_copied ? "Copied!" : "Copy command")">
            @if (_copied)
            {
                <LuCheck class="size-4 transition-colors duration-200 text-emerald-600" />
            }
            else
            {
                <LuCopy class="size-4 transition-colors duration-200" />
            }
        </Button>
    </div>

    <style>
        .docs-codeblock .hljs-meta {
            color: #ae93ea;
        }
    </style>
    <div class="docs-codeblock command-block docs-codeblock--solo">
        <pre class="flex-1 min-w-0 !px-4 !py-3 overflow-x-auto max-lg:text-[0.6rem] lg:text-sm font-mono leading-[1.65] m-0 border-0 whitespace-pre !bg-background">
            <code id="@_codeId" class="!text-[#a7cafa] language-command">
                @Command
            </code>
        </pre>
    </div>
</div>
