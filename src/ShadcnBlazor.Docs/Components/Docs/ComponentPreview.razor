@using EasyAppDev.Blazor.Icons.Lucide
@using ShadcnBlazor.Docs.Components.Docs.CodeBlock

@inherits ShadcnComponentBase

<div class="w-full min-w-0 rounded-lg border border-border overflow-hidden">
<div class="@(MergeCss("relative max-lg:py-12 max-lg:px-6 lg:p-[7.5%] flex justify-center items-center min-w-0", Class))">
        <div class="flex justify-center items-center w-full max-w-full min-w-0 overflow-x-hidden">
            @ChildContent
        </div>
        
        @if (HasCode && !DisableHide)
        {
            <Button Size="@Size.Md"
                    Variant="@Variant.Ghost"
                    Class="absolute top-2 right-2 text-xs text-muted-foreground hover:text-foreground"
                    OnClick="ToggleShowCode">
                @if (_showCode)
                {
                    <LuChevronUp class="size-3.5" />
                    @("Hide code")
                }
                else
                {
                    <LuCode class="size-3.5" />
                    @("Show code")
                }
            </Button>
        }
    </div>

    @if (HasCode)
    {
        <div class="docs-codeblock-accordion @((_showCode || DisableHide) ? "docs-codeblock-accordion-expanded" : "") overflow-hidden @((_showCode || DisableHide) ? "border-t border-border" : "") relative" inert="@((_showCode || DisableHide) ? null : "true")">
            <div class="docs-codeblock-accordion-inner min-w-0 overflow-y-auto @InnerClass">
                <CodeBlock CodeFiles="@CodeFiles" Style="@CodeBlockStyle.Embedded" Focusable="@(_showCode || DisableHide)" AllowVerticalScroll="false" HighlightedLines="@HighlightedLines" />
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public bool DisableHide { get; set; } = false;

    [Parameter]
    public string InnerClass { get; set; } = string.Empty;

    [Parameter]
    public bool AllowVerticalScroll { get; set; } = false;

    private bool _showCode;
    private bool HasCode => CodeFiles is { Count: > 0 } files && files.Any(f => !string.IsNullOrWhiteSpace(f.Contents));

    private void ToggleShowCode()
    {
        _showCode = !_showCode;
    }
}
