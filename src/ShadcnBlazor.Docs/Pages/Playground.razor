@page "/playground"
@using ShadcnBlazor.Docs.Components.Examples
@using ShadcnBlazor.Services
@inject VaulService Vaul

<PageTitle>Playground - Vaul</PageTitle>

<div class="w-full max-w-2xl mx-auto p-8 mb-[100vh]">
    <div class="space-y-6">
        <div>
            <h1>Vaul Drawer</h1>
            <p>Minimal Vaul drawer demo powered by the interop bundle.</p>
        </div>

        <section class="space-y-4">
            <div class="flex items-center gap-4">
                <button
                    class="relative flex h-10 flex-shrink-0 items-center justify-center gap-2 overflow-hidden rounded-full bg-white px-4 text-sm font-medium shadow-sm transition-all hover:bg-[#FAFAFA] dark:bg-[#161615] dark:hover:bg-[#1A1A19] dark:text-white"
                    @onclick="OpenVaulDrawer">
                    Open Drawer
                </button>
            </div>
        </section>

        <section class="space-y-3">
            <div class="flex items-center gap-4">
                <button
                    class="relative flex h-10 flex-shrink-0 items-center justify-center gap-2 overflow-hidden rounded-full bg-white px-4 text-sm font-medium shadow-sm transition-all hover:bg-[#FAFAFA] dark:bg-[#161615] dark:hover:bg-[#1A1A19] dark:text-white"
                    @onclick="OpenVaulDrawerWithCallbacks">
                    Open Drawer (Callbacks)
                </button>
                <button
                    class="text-sm text-slate-600 underline"
                    @onclick="ClearCallbackLog">
                    Clear log
                </button>
            </div>
            <div class="rounded-md border border-slate-200 bg-slate-50 p-3 text-xs text-slate-700">
                <div class="font-medium mb-2">Callback log</div>
                <div>@(string.IsNullOrWhiteSpace(_callbackLog) ? "No events yet." : _callbackLog)</div>
            </div>
        </section>

    </div>
</div>

@code {
    private string? _vaulDrawerId;
    private string? _callbackDrawerId;
    private string _callbackLog = string.Empty;

    private async Task OpenVaulDrawer()
    {
        if (_vaulDrawerId is not null)
        {
            await Vaul.CloseAsync(_vaulDrawerId);
        }

        var parameters = new Dictionary<string, object?>
        {
            ["Title"] = "Drawer for React.",
            ["Message"] = "This component can be used as a Dialog replacement on mobile and tablet devices.",
        };

        var options = new
        {
            title = "Drawer for React.",
            description = "Vaul drawer demo content.",
            a11yHidden = true,
            overlay = new
            {
                className = "fixed inset-0 bg-black/40",
                disableBaseClass = true
            },
            content = new
            {
                className = "bg-gray-100 flex flex-col rounded-t-[10px] mt-24 h-fit fixed bottom-0 left-0 right-0 outline-none",
                disableBaseClass = true
            }
        };

        _vaulDrawerId = await Vaul.OpenAsync<VaulPlaygroundDemo>(parameters, options);
    }

    private async Task OpenVaulDrawerWithCallbacks()
    {
        if (_callbackDrawerId is not null)
        {
            await Vaul.CloseAsync(_callbackDrawerId);
        }

        var options = new VaulOptions
        {
            Title = "The Hidden Details",
            Description = "Snap points demo inspired by the Vaul docs.",
            A11yHidden = true,
            Overlay = new VaulOverlayOptions
            {
                ClassName = "fixed inset-0 bg-black/40",
                DisableBaseClass = true
            },
            Content = new VaulContentOptions
            {
                ClassName = "fixed flex flex-col bg-white border border-gray-200 border-b-none rounded-t-[10px] bottom-0 left-0 right-0 h-full max-h-[97%] mx-[-1px]",
                DisableBaseClass = true
            },
            Drawer = new VaulDrawerOptions
            {
                Dismissible = true,
                Modal = true,
                SnapPoints = new object[] { "148px", "355px", 1 },
            }
        };

        var callbacks = new VaulCallbacks
        {
            OnOpenChange = open => _ = AppendLogAsync($"OpenChange: {open}"),
            OnClose = () => _ = AppendLogAsync("Close"),
            OnDrag = value => _ = AppendLogAsync($"Drag: {value:0.00}"),
            OnRelease = open => _ = AppendLogAsync($"Release: {open}"),
            OnAnimationEnd = open => _ = AppendLogAsync($"AnimationEnd: {open}"),
            OnSnapPointChange = value => _ = UpdateSnapPointAsync(value)
        };

        _callbackDrawerId = await Vaul.OpenAsync<VaulSnapPointsDemo>(null, options, callbacks);
    }

    private async Task CloseVaulDrawer()
    {
        if (_vaulDrawerId is null)
        {
            return;
        }

        await Vaul.CloseAsync(_vaulDrawerId);
        _vaulDrawerId = null;
    }

    private async Task AppendLogAsync(string message)
    {
        await InvokeAsync(() =>
        {
            if (!string.IsNullOrWhiteSpace(_callbackLog))
            {
                _callbackLog = $"{_callbackLog} | ";
            }

            _callbackLog = $"{_callbackLog}{message}";
            StateHasChanged();
        });
    }

    private async Task UpdateSnapPointAsync(object? value)
    {
        await AppendLogAsync($"SnapPoint: {value ?? "null"}");
    }

    private void ClearCallbackLog()
    {
        _callbackLog = string.Empty;
    }
}
