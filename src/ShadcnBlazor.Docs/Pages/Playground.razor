@page "/playground"
@using Microsoft.AspNetCore.Components
@using ShadcnBlazor.Docs.Components.Examples
@using ShadcnBlazor.Services
@inject SonnerService Sonner

<PageTitle>Playground - Sonner + Blazor</PageTitle>

<div class="w-full max-w-2xl mx-auto p-8">
    <div class="space-y-6">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">Sonner Toast Notifications</h1>
            <p class="text-muted-foreground mt-2">Beautiful, accessible toast notifications with Blazor.</p>
        </div>

        <!-- Basic Toasts -->
        <section class="space-y-4">
            <h2 class="text-xl font-semibold">Basic Toasts</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <button
                    class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-md transition-colors"
                    @onclick="ShowBasicToast">
                    Show Toast
                </button>

                <button
                    class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-medium rounded-md transition-colors"
                    @onclick="ShowSuccessToast">
                    Success
                </button>

                <button
                    class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white font-medium rounded-md transition-colors"
                    @onclick="ShowErrorToast">
                    Error
                </button>

                <button
                    class="px-4 py-2 bg-yellow-600 hover:bg-yellow-700 text-white font-medium rounded-md transition-colors"
                    @onclick="ShowWarningToast">
                    Warning
                </button>
            </div>
        </section>

        <!-- Interactive Toasts -->
        <section class="space-y-4">
            <h2 class="text-xl font-semibold">Interactive Toasts</h2>
            <p class="text-sm text-muted-foreground">
                Toasts with action buttons that trigger C# callbacks
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <button
                    class="px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white font-medium rounded-md transition-colors"
                    @onclick="ShowUndoToast">
                    Undo Action
                </button>

                <button
                    class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-md transition-colors"
                    @onclick="ShowRetryToast">
                    Retry Failed Action
                </button>

                <button
                    class="px-4 py-2 bg-pink-600 hover:bg-pink-700 text-white font-medium rounded-md transition-colors"
                    @onclick="ShowMultipleToasts">
                    Show Multiple (5)
                </button>

                <button
                    class="px-4 py-2 bg-orange-600 hover:bg-orange-700 text-white font-medium rounded-md transition-colors"
                    @onclick="() => Sonner.Dismiss()">
                    Dismiss All
                </button>
            </div>
        </section>

        <!-- Promise Toasts -->
        <section class="space-y-4">
            <h2 class="text-xl font-semibold">Promise Toasts</h2>
            <p class="text-sm text-muted-foreground">
                Track async operations with automatic loading, success, and error states
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <button
                    class="px-4 py-2 bg-teal-600 hover:bg-teal-700 text-white font-medium rounded-md transition-colors"
                    @onclick="ShowPromiseToast">
                    Async Operation (Success)
                </button>

                <button
                    class="px-4 py-2 bg-rose-600 hover:bg-rose-700 text-white font-medium rounded-md transition-colors"
                    @onclick="ShowPromiseErrorToast">
                    Async Operation (Error)
                </button>
            </div>
        </section>

        <!-- Component Toasts -->
        <section class="space-y-4">
            <h2 class="text-xl font-semibold">Component Toasts</h2>
            <p class="text-sm text-muted-foreground">
                Render full Blazor components or RenderFragments inside toasts
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <button
                    class="px-4 py-2 bg-cyan-600 hover:bg-cyan-700 text-white font-medium rounded-md transition-colors"
                    @onclick="ShowComponentToast">
                    Component Toast
                </button>
            </div>
        </section>

        <!-- Info Box -->
        <div class="bg-slate-100 dark:bg-slate-900 rounded-lg p-4">
            <h3 class="font-semibold text-sm mb-2">Features</h3>
            <ul class="text-sm text-muted-foreground space-y-1">
                <li>✓ Beautiful, themed toast notifications</li>
                <li>✓ Dark mode support (uses app's dark class)</li>
                <li>✓ Custom design tokens for consistent styling</li>
                <li>✓ Action buttons with C# callbacks</li>
                <li>✓ Dismiss individual or all toasts</li>
                <li>✓ Icon-based notifications (success, error, warning, info)</li>
                <li>✓ RenderFragment and component toasts with full interactivity</li>
            </ul>
        </div>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await Sonner.InitializeAsync();
    }

    private async Task ShowBasicToast() => await Sonner.Show("This is a basic notification");

    private async Task ShowSuccessToast() => await Sonner.Success("Operation completed successfully!");

    private async Task ShowErrorToast() => await Sonner.Error("An error occurred. Please try again.");

    private async Task ShowWarningToast() => await Sonner.Warning("Be careful with this action.");

    private async Task ShowUndoToast()
    {
        await Sonner.SuccessWithAction(
            "Event created successfully",
            "Undo",
            async () =>
            {
                await Sonner.Show("Event creation undone");
            }
        );
    }

    private async Task ShowRetryToast()
    {
        await Sonner.ErrorWithAction(
            "Failed to upload file",
            "Retry",
            async () =>
            {
                await Sonner.Success("File uploaded successfully!");
            }
        );
    }

    private async Task ShowMultipleToasts()
    {
        var messages = new[]
        {
            ("Database sync started", "show"),
            ("Validating data...", "show"),
            ("Processing...", "show"),
            ("Synced successfully!", "success"),
            ("Ready to go!", "success")
        };

        foreach (var (msg, type) in messages)
        {
            await Task.Delay(300);
            if (type == "success")
                await Sonner.Success(msg);
            else
                await Sonner.Show(msg);
        }
    }

    private async Task ShowPromiseToast()
    {
        await Sonner.PromiseAsync(
            SimulateAsyncOperation(2000),
            "Processing your request...",
            "Operation completed successfully!",
            "Something went wrong during processing"
        );
    }

    private async Task ShowPromiseErrorToast()
    {
        await Sonner.PromiseAsync(
            SimulateAsyncOperationWithError(2000),
            "Processing your request...",
            "Operation completed successfully!",
            "Operation failed as expected"
        );
    }

    private async Task<string> SimulateAsyncOperation(int delayMs)
    {
        await Task.Delay(delayMs);
        return "Success";
    }

    private async Task<string> SimulateAsyncOperationWithError(int delayMs)
    {
        await Task.Delay(delayMs);
        throw new Exception("Simulated error");
    }

    private async Task ShowComponentToast()
    {
        var parameters = new Dictionary<string, object?>
        {
            ["Title"] = "Headless Blazor Toast",
            ["Message"] = "Custom layout using toast.custom with Sonner animations.",
            ["ButtonLabel"] = "Reply",
            ["OnConfirm"] = EventCallback.Factory.Create(this, OnComponentConfirmed)
        };

        await Sonner.ShowHeadlessAsync<SonnerHeadlessToast>(parameters);
    }

    private async Task OnComponentConfirmed()
    {
        await Sonner.Success("Component confirmed!");
    }
}
