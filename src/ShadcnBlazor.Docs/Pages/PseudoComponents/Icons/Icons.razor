@page "/components/icons"
@using ShadcnBlazor.Docs.Components.Docs.CodeBlock
@using ShadcnBlazor.Docs.Pages.PseudoComponents.Icons.Examples

<PageTitle>Icons - ShadcnBlazor</PageTitle>
<HeadContent>
    <meta name="description" content="ShadcnBlazor Icons - Browse and use Lucide icons in your Blazor components with easy integration." />
</HeadContent>

<TocPageBase>
<div class="flex flex-col gap-8 min-w-0">
    <div class="flex flex-col gap-1">
        <h1>Icons</h1>
        <p>
            ShadcnBlazor does not ship an icon library. Use any icon set you prefer—we recommend Lucide icons for consistency with shadcn/ui.
        </p>
    </div>

    <p>
            The shadcn/ui ecosystem uses <a href="https://lucide.dev/" target="_blank" rel="noopener" class="hover:underline">Lucide</a> icons. For Blazor, you can use <code>EasyAppDev.Blazor.Icons.Lucide</code> or any other icon package. Icons are just components or SVG—place them inside buttons, inputs, or anywhere in your markup.
        </p>

    <DocsSection Title="Using Lucide Icons" Id="lucide">
        <p>
            Add the Lucide Blazor package to your project:
        </p>
        <CodeBlock CodeFiles="@(new[] { CodeFile.Create(InstallExample, "xml") })" />
        <p>
            Then use icon components in your Razor files. Icons are named with a <code>Lu</code> prefix (e.g. <code>LuHome</code>, <code>LuSettings</code>). Size them with Tailwind classes like <code>h-4 w-4</code> or <code>size-5</code>.
        </p>

        <DocsSubSection Title="Icons in Buttons" Id="buttons">
            <p>
                Place icons alongside text or use icon-only buttons. The Button component's built-in gap handles spacing.
            </p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.PseudoComponents_Icons_Examples_IconsInButtonsExample })">
                <IconsInButtonsExample />
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="Common Icons" Id="common">
            <p>
                A few frequently used icons: <code>LuHome</code>, <code>LuUser</code>, <code>LuSearch</code>, <code>LuChevronRight</code>, <code>LuCheck</code>. Browse the full set at <a href="https://lucide.dev/icons/" target="_blank" rel="noopener" class="hover:underline">lucide.dev</a>.
            </p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.PseudoComponents_Icons_Examples_IconsCommonExample })">
                <IconsCommonExample />
            </ComponentPreview>
        </DocsSubSection>
    </DocsSection>

    <DocsSection Title="Other Icon Libraries" Id="alternatives">
        <p>
            You can use any icon library that renders SVG or components. Popular options include:
        </p>
        <ul>
            <li><strong>Lucide</strong> — Used by shadcn/ui; clean, consistent design.</li>
            <li><strong>Heroicons</strong> — From Tailwind Labs; similar aesthetic.</li>
            <li><strong>Custom SVG</strong> — Inline SVG or your own component library.</li>
        </ul>
        <p>
            ShadcnBlazor components accept any content via <code>ChildContent</code> or slots, so icons integrate seamlessly regardless of source.
        </p>
    </DocsSection>
</div>
</TocPageBase>

@code {
    private const string InstallExample = @"<PackageReference Include=""EasyAppDev.Blazor.Icons.Lucide"" Version=""2.0.4"" />";
}



