@page "/components/skeleton"

<PageTitle>Skeleton - ShadcnBlazor</PageTitle>
<HeadContent>
    <meta name="description" content="ShadcnBlazor Skeleton - Placeholder loading state for improved perceived performance." />
</HeadContent>
@using System.Reflection
@using ShadcnBlazor.Docs.Pages.Components.Skeleton.Examples
@using ShadcnBlazor.Docs.Services

<ComponentDocPage Metadata="@Metadata"
                 InstallCommand="@InstallCommand"
                 ApiDoc="@ApiDocumentation.Skeleton">
    <ComponentPreview DisableHide AllowVerticalScroll InnerClass="max-h-[35vh]" CodeFiles="@(new[] { Snippets.Components_Skeleton_Examples_SkeletonBasicExample })">
            <SkeletonBasicExample />
        </ComponentPreview>

        <FeaturesSection Title="Features" Id="features" Features="@Features" SourceLink="Skeleton" />

        <DocsSection Title="About" Id="about">
            <p>The Skeleton component displays a loading placeholder with a pulse animation. Use the <code>Class</code> parameter to customize the shape (e.g., <code>h-12 w-12 rounded-full</code> for avatars, <code>h-4 w-[250px]</code> for text lines).</p>
        </DocsSection>

        <InstallationCommand InstallCommand="@InstallCommand" Metadata="@Metadata" />

    

    <DocsSection Title="Examples" Id="examples">
        <DocsSubSection Title="Shapes" Id="shapes">
            <p>Combine Skeleton components with different <code>Class</code> values to build loading states for cards, avatars, or form layouts.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Skeleton_Examples_SkeletonShapesExample })">
                <SkeletonShapesExample />
            </ComponentPreview>
        </DocsSubSection>
    </DocsSection>
</ComponentDocPage>

@code {
    private static readonly ComponentMetadata Metadata = ComponentRegistryService.GetMetadata("Skeleton");

    private const string InstallCommand = "shadcnblazor component add skeleton";

    private List<RenderFragment> Features => new()
    {
        __builder => { <div>Visual placeholder for loading states</div> },
        __builder => { <div>Automatic pulse animation effect</div> },
        __builder => { <div>Flexible sizing and configurable shapes</div> },
        __builder => { <div>Easily composable in UI layouts</div> },
    };
}



