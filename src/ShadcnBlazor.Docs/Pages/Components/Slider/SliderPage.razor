@page "/components/slider"

<PageTitle>Slider - ShadcnBlazor</PageTitle>
<HeadContent>
    <meta name="description" content="ShadcnBlazor Slider - Slider control for selecting numeric values." />
</HeadContent>
@using System.Reflection
@using ShadcnBlazor.Docs.Pages.Components.Slider.Examples
@using ShadcnBlazor.Docs.Services

<ComponentDocPage Metadata="@Metadata"
                 InstallCommand="@InstallCommand"
                 ApiDoc="@ApiDocumentation.Slider">
    <ComponentPreview DisableHide AllowVerticalScroll InnerClass="max-h-[35vh]" CodeFiles="@(new[] { Snippets.Components_Slider_Examples_SliderBasicExample })">
            <div class="w-full lg:mx-[clamp(5%,10%,10%)]">
                <SliderBasicExample />
            </div>
        </ComponentPreview>

        <FeaturesSection Title="Features" Id="features" Features="@Features" SourceLink="Slider" />

        <DocsSection Title="About" Id="about">
            <p>The Slider component lets users select a value within a range. Use <code>Min</code>, <code>Max</code>, and <code>Step</code> to define the range. Bind <code>Value</code> for single-thumb mode or <code>Values</code> for multi-thumb mode.</p>
        </DocsSection>

        <InstallationCommand InstallCommand="@InstallCommand" Metadata="@Metadata" />

    

    <DocsSection Title="Examples" Id="examples">
        <DocsSubSection Title="Range" Id="range">
            <p>Use <code>@@bind-Values</code> with a list of values to create a range slider with multiple thumbs.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Slider_Examples_SliderRangeExample })">
                <div class="w-full lg:mx-[clamp(5%,10%,10%)]">
                    <SliderRangeExample />
                </div>
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="Multiple Thumbs" Id="multiple">
            <p>Create sliders with three or more independent thumbs by binding a list of values.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Slider_Examples_SliderMultipleExample })">
                <div class="w-full lg:mx-[clamp(5%,10%,10%)]">
                    <SliderMultipleExample />
                </div>
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="Disabled" Id="disabled">
            <p>Use the <code>Disabled</code> parameter to prevent user interaction.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Slider_Examples_SliderDisabledExample })">
                <div class="w-full lg:mx-[clamp(5%,10%,10%)]">
                    <SliderDisabledExample />
                </div>
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="Sizes" Id="sizes">
            <p>The <code>Size</code> parameter controls the track and thumb dimensions. Choose from <code>Size.Sm</code>, <code>Size.Md</code>, or <code>Size.Lg</code>.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Slider_Examples_SliderSizesExample })">
                <div class="w-full lg:mx-[clamp(5%,10%,10%)]">
                    <SliderSizesExample />
                </div>
            </ComponentPreview>
        </DocsSubSection>
    </DocsSection>
</ComponentDocPage>

@code {
    private static readonly ComponentMetadata Metadata = ComponentRegistryService.GetMetadata("Slider");

    private const string InstallCommand = "shadcnblazor component add slider";

    private List<RenderFragment> Features => new()
    {
        __builder => { <div>Range selection via dragging thumbs</div> },
        __builder => { <div>Step increment snapping and limits</div> },
        __builder => { <div>Keyboard support for fine tuning</div> },
        __builder => { <div>Optional multiple thumbs for ranges</div> },
    };
}



