<div class="flex flex-col gap-3">
    <div class="flex items-center gap-2">
        <Checkbox Id="email" Value="@_selected.Contains("email")" ValueChanged="@(v => Toggle("email", v))" />
        <Label For="email">Email notifications</Label>
    </div>
    <div class="flex items-center gap-2">
        <Checkbox Id="sms" Value="@_selected.Contains("sms")" ValueChanged="@(v => Toggle("sms", v))" />
        <Label For="sms">SMS notifications</Label>
    </div>
    <div class="flex items-center gap-2">
        <Checkbox Id="push" Value="@_selected.Contains("push")" ValueChanged="@(v => Toggle("push", v))" />
        <Label For="push">Push notifications</Label>
    </div>
</div>
<p class="text-sm text-muted-foreground mt-4">Selected: @string.Join(", ", _selected)</p>

@code {
    private HashSet<string> _selected = new();

    private void Toggle(string value, bool checked_)
    {
        if (checked_)
            _selected.Add(value);
        else
            _selected.Remove(value);
    }
}
