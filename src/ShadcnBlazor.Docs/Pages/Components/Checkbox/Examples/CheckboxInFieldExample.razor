<Field FieldId="terms">
    <div class="flex gap-2">
        <Checkbox Id="accept-terms" @bind-Value="_acceptTerms" />
        <div class="flex flex-col gap-1">
            <FieldLabel For="accept-terms">Accept terms and conditions</FieldLabel>
            <FieldDescription>By checking this box, you agree to our terms of service and privacy policy.</FieldDescription>
        </div>
    </div>
</Field>

@code {
    private bool _acceptTerms;
}
