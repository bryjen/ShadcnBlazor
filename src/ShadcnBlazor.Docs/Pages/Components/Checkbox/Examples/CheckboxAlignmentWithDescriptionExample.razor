<div class="flex gap-2 items-start">
    <Checkbox Id="terms" @bind-Value="_checked" />
    <div class="flex flex-col gap-1">
        <Label For="terms" Class="font-semibold">Accept terms and conditions</Label>
        <p class="text-sm text-muted-foreground">By clicking this checkbox, you agree to the terms and conditions.</p>
    </div>
</div>

@code {
    private bool _checked;
}
