@page "/components/button"

<PageTitle>Button - ShadcnBlazor</PageTitle>
<HeadContent>
    <meta name="description" content="ShadcnBlazor Button - Interactive clickable elements with multiple variants and sizes." />
</HeadContent>
@using System.Reflection
@using ShadcnBlazor.Docs.Pages.Components.Button.Examples
@using ShadcnBlazor.Docs.Services

<ComponentDocPage Metadata="@Metadata"
                 InstallCommand="@InstallCommand"
                 ApiDoc="@ApiDocumentation.Button">
    <UnderHeader>
        <div class="w-fit">
            <Badge Size="@Size.Md">
                <span class="font-semibold">Accessible</span>
            </Badge>
        </div>
    </UnderHeader>

    <ChildContent>
        <FeaturesSection Title="Features" Id="features" Features="@Features" SourceLink="Button" />

    <DocsSection Title="Usage" Id="usage">
        <p class="mb-3">Basic button with text content. Use <code>ChildContent</code> to render anything inside—text, markup, or components. For icon-only buttons, provide <code>AriaLabel</code> for screen reader users.</p>
        <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Button_Examples_ButtonBasicExample })">
            <ButtonBasicExample />
        </ComponentPreview>
    </DocsSection>

    <DocsSection Title="Examples" Id="examples">
        <DocsSubSection Title="Size" Id="size">
            <p class="mb-3">Use the <code>Size</code> parameter for compact (Sm), default (Md), or larger (Lg) buttons. Sizing affects padding and text scale.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Button_Examples_ButtonSizeExample })">
                <ButtonSizeExample />
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="Variants" Id="variants">
            <p class="mb-3">Choose a <code>Variant</code> to convey hierarchy: Default for primary actions, Outline for secondary, Ghost for minimal emphasis, Destructive for dangerous actions, and Link for inline-style buttons.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Button_Examples_ButtonVariantExample })">
                <ButtonVariantExample />
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="Content" Id="content">
            <p class="mb-3">The button accepts any content via <code>ChildContent</code>. Mix text with inline elements, or use dynamic content. The component handles layout and spacing automatically.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Button_Examples_ButtonContentExample })">
                <ButtonContentExample />
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="Icons" Id="icons">
            <p class="mb-3">Use Lucide icons (or any SVG) inside the button. Add the icon package and place it alongside text—spacing is handled by the button's built-in gap. Icon-only buttons work with smaller sizes and padding.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Button_Examples_ButtonIconExample })">
                <ButtonIconExample />
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="Icon-only buttons" Id="icon-only">
            <p class="mb-3">For icon-only buttons, provide <code>AriaLabel</code> so screen readers announce the button's purpose (e.g., "Delete", "Save", "Toggle menu").</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Button_Examples_ButtonIconOnlyExample })">
                <ButtonIconOnlyExample />
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="Spinner" Id="spinner">
            <p class="mb-3">Use <code>State="ButtonState.Loading"</code> for async actions. The button is disabled and gets <code>aria-busy="true"</code> so screen readers announce that it's processing. Render a spinner inside for visual feedback.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Button_Examples_ButtonSpinnerExample })">
                <ButtonSpinnerExample />
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="Disabled" Id="disabled">
            <p class="mb-3">Use <code>State="ButtonState.Disabled"</code> when the action is unavailable. Unlike Loading, this sets <code>aria-disabled="true"</code> (not <code>aria-busy</code>)—screen readers announce "disabled" rather than "busy", so users understand the control is inactive, not processing.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Button_Examples_ButtonDisabledExample })">
                <ButtonDisabledExample />
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="Interactivity" Id="interactivity">
            <p class="mb-3">Wire up <code>OnClick</code> to handle user actions. The handler receives <code>MouseEventArgs</code>. Use component state to drive dynamic labels or behavior.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Button_Examples_ButtonCounterExample })">
                <ButtonCounterExample />
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="Button Group" Id="button-group">
            <p class="mb-3">Use <code>ButtonGroup</code> to group related buttons with shared borders and styling. Set <code>Variant</code> for Default, Outline, Ghost, or other styles. Provide <code>AriaLabel</code> to describe the group's purpose (e.g., "Text formatting", "Pagination"). Use <code>Role="toolbar"</code> for toolbar groups.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Button_Examples_ButtonGroupExample })">
                <ButtonGroupExample />
            </ComponentPreview>
        </DocsSubSection>
    </DocsSection>

    <DocsSection Title="Accessibility" Id="accessibility">
        <p class="mb-3">Icon-only buttons require <code>AriaLabel</code> to describe their action for screen readers. Buttons with visible text don't need AriaLabel unless you want to provide additional context (e.g., "Delete permanently").</p>
        <p class="mb-3">Loading state sets <code>aria-busy="true"</code> automatically. Disabled state sets <code>aria-disabled="true"</code>. When used as popover or form triggers, proper ARIA attributes are set automatically.</p>
        <p><code>ButtonGroup</code> should have an <code>AriaLabel</code> describing what the grouped buttons control.</p>
    </DocsSection>
    </ChildContent>
</ComponentDocPage>

@code {
    private static readonly ComponentMetadata Metadata = ComponentRegistryService.GetMetadata("Button");

    private const string InstallCommand = "shadcnblazor component add button";

    private List<RenderFragment> Features => new()
    {
        __builder => { <div>ARIA labels for icon-only buttons</div> },
        __builder => { <div>Loading state with aria-busy automatic announcement</div> },
        __builder => { <div>Disabled state with proper aria-disabled attribute</div> },
        __builder => { <div>Popover and form validation ARIA support</div> },
        __builder => { <div>ButtonGroup with semantic grouping and aria-label</div> },
    };
}

