@page "/components/dialog"

<PageTitle>Dialog - ShadcnBlazor</PageTitle>
<HeadContent>
    <meta name="description" content="ShadcnBlazor Dialog - Modal dialog for user interactions and confirmations." />
</HeadContent>

@using ShadcnBlazor.Docs.Pages.Components.Dialog.Examples

<ComponentDocPage Metadata="@Metadata"
                 InstallCommand="@InstallCommand">
    <DocsSection Title="Usage" Id="usage">
        <p>Compose dialogs inline using <code>DialogRoot</code>, <code>DialogTrigger</code>, and <code>DialogContent</code>. Use <code>@@ref</code> on <code>DialogRoot</code> to access <code>OpenDialog()</code> and <code>CloseAsync()</code> methods for explicit control.</p>
        <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Dialog_Examples_DialogShowcase })">
            <DialogShowcase />
        </ComponentPreview>
    </DocsSection>

    <DocsSection Title="Separate Files" Id="separate-files">
        <ComponentPreview CodeFiles="@(new[] {
                                         Snippets.Components_Dialog_Examples_SeparateFiles_Main,
                                         Snippets.Components_Dialog_Examples_SeparateFiles_Dialog })"
                          HighlightedLines="@(new []{ "3,22-27", "3-4,40-64"})">
            <ShadcnBlazor.Docs.Pages.Components.Dialog.Examples.SeparateFiles.Main/>
        </ComponentPreview>
    </DocsSection>

    <DocsSection Title="Abstracting Separate Files" Id="abstracting-separate-files">
        <ComponentPreview CodeFiles="@(new[] {
                                         Snippets.Components_Dialog_Examples_SeparateFilesAbstraction_AbstractDialog_cs,
                                         Snippets.Components_Dialog_Examples_SeparateFilesAbstraction_ConcreteDialog,
                                         Snippets.Components_Dialog_Examples_SeparateFilesAbstraction_Main })"
                          HighlightedLines="@(new []{ "6-40", "", "" })">
            <ShadcnBlazor.Docs.Pages.Components.Dialog.Examples.SeparateFiles.Main/>
        </ComponentPreview>
    </DocsSection>

    <DocsSection Title="DialogRoot Options" Id="options">
        <ul>
            <li><code>CloseOnBackdropClick</code> - Whether clicking the backdrop closes the dialog. Default: true</li>
            <li><code>CloseOnEscapeKey</code> - Whether pressing Escape closes the dialog. Default: true</li>
        </ul>
    </DocsSection>

    <DocsSection Title="Example" Id="example">
        <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Dialog_Examples_DeclarativeDialogExample })">
            <DeclarativeDialogExample />
        </ComponentPreview>
    </DocsSection>
</ComponentDocPage>

@code {
    private static readonly ComponentMetadata Metadata = ComponentRegistryService.GetMetadata("Dialog");

    private const string InstallCommand = "shadcnblazor component add dialog";
}


