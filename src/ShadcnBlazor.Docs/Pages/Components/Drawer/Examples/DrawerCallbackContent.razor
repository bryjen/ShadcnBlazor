<div class="flex flex-col max-w-md mx-auto w-full p-4 pt-5 overflow-y-auto">
    <div class="mx-auto w-12 h-1.5 flex-shrink-0 rounded-full bg-popover-foreground/20 mb-8"></div>
    <h2 class="text-2xl font-medium text-popover-foreground mb-2">Callback Demo</h2>
    <p class="text-sm text-popover-foreground mb-6">
        Interact with this drawer to see events logged in the event log above. Try dragging, closing, or waiting for animations to complete.
    </p>

    <div class="space-y-4">
        <div>
            <h3 class="font-medium text-popover-foreground mb-2">Available Callbacks:</h3>
            <ul class="text-sm text-popover-foreground space-y-1 list-disc list-inside">
                <li><code class="bg-popover/50 px-1 rounded">OnOpenChange</code> - When drawer opens/closes</li>
                <li><code class="bg-popover/50 px-1 rounded">OnClose</code> - When drawer closes</li>
                <li><code class="bg-popover/50 px-1 rounded">OnDrag</code> - While dragging</li>
                <li><code class="bg-popover/50 px-1 rounded">OnRelease</code> - After releasing drag</li>
                <li><code class="bg-popover/50 px-1 rounded">OnAnimationEnd</code> - When animation completes</li>
            </ul>
        </div>
    </div>
</div>
