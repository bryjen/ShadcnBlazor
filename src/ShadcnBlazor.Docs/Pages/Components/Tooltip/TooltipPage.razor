@page "/components/tooltip"

<PageTitle>Tooltip - ShadcnBlazor</PageTitle>
<HeadContent>
    <meta name="description" content="ShadcnBlazor Tooltip - Small popup displaying helpful information on hover." />
</HeadContent>
@using System.Reflection
@using ShadcnBlazor.Docs.Pages.Components.Tooltip.Examples
@using ShadcnBlazor.Docs.Services

<ComponentDocPage Metadata="@Metadata"
                 InstallCommand="@InstallCommand"
                 ApiDoc="@ApiDocumentation.Tooltip">
    <ComponentPreview DisableHide AllowVerticalScroll InnerClass="max-h-[35vh]" CodeFiles="@(new[] { Snippets.Components_Tooltip_Examples_TooltipBasicExample })">
            <TooltipBasicExample />
        </ComponentPreview>

        <FeaturesSection Title="Features" Id="features" Features="@Features" SourceLink="Tooltip" />

        <DocsSection Title="About" Id="about">
            <p>The Tooltip component displays a floating label on hover. Use <code>Anchor</code> for the trigger element (e.g., icon or button) and <code>Content</code> or <code>ChildContent</code> for the tooltip text. Requires <code>PopoverProvider</code> in your layout (already present in the docs).</p>
        </DocsSection>

        <InstallationCommand InstallCommand="@InstallCommand" Metadata="@Metadata" />

    

    <DocsSection Title="Examples" Id="examples">
        <DocsSubSection Title="Add to library" Id="add-to-library">
            <p>Simple tooltip with <code>Content</code> on an icon button.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Tooltip_Examples_TooltipAddToLibraryExample })">
                <TooltipAddToLibraryExample />
            </ComponentPreview>
        </DocsSubSection>
        <DocsSubSection Title="Multiline" Id="multiline">
            <p>Use <code>ChildContent</code> for custom tooltip content (e.g., multiline text with line breaks).</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Tooltip_Examples_TooltipMultilineExample })">
                <TooltipMultilineExample />
            </ComponentPreview>
        </DocsSubSection>
    </DocsSection>
</ComponentDocPage>

@code {
    private static readonly ComponentMetadata Metadata = ComponentRegistryService.GetMetadata("Tooltip");

    private const string InstallCommand = "shadcnblazor component add tooltip";

    private List<RenderFragment> Features => new()
    {
        __builder => { <div>Hover or focus activated micro-content</div> },
        __builder => { <div>Delayed opening and closing configurations</div> },
        __builder => { <div>Advanced positioning via Floating UI</div> },
        __builder => { <div>Accessibility friendly keyboard support</div> },
    };
}



