@inject SonnerService SonnerService

<div class="flex flex-col gap-2">
    <Button Variant="@Variant.Outline" Size="@Size.Sm" OnClick="ShowCustom">Show Custom</Button>
    <Button Variant="@Variant.Outline" Size="@Size.Sm" OnClick="ShowCustomHeadless">Show Custom Headless</Button>
</div>

@code {
    private RenderFragment CustomToast => @<div class="flex items-center gap-3">
        <div>
            <p class="font-semibold">This is a custom toast</p>
            <p class="text-sm text-muted-foreground">Rendered directly from a RenderFragment</p>
        </div>
        <Button Variant="@Variant.Outline" Size="@Size.Sm" OnClick="OnToastAction">Action</Button>
    </div>;

    private async Task ShowCustom()
    {
        await SonnerService.ShowCustomAsync(CustomToast);
    }

    private async Task ShowCustomHeadless()
    {
        await SonnerService.ShowHeadlessAsync(CustomToast);
    }

    private async Task OnToastAction()
    {
        await SonnerService.Success("Action confirmed!");
    }
}
