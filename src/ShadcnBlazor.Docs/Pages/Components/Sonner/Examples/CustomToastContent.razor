@namespace ShadcnBlazor.Docs.Pages.Components.Sonner.Examples

<div class="flex items-center gap-3 p-2">
    <div class="flex-1">
        <p class="text-sm font-medium">@Message</p>
        <p class="text-xs text-muted-foreground mt-1">Custom component rendered in a toast</p>
    </div>
    <button
        class="px-3 py-1 text-xs bg-blue-600 hover:bg-blue-700 text-white rounded"
        @onclick="OnActionClick">
        Action
    </button>
</div>

@code {
    [Parameter]
    public string? Message { get; set; }

    [Parameter]
    public EventCallback OnAction { get; set; }

    private async Task OnActionClick()
    {
        await OnAction.InvokeAsync();
    }
}
