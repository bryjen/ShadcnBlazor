<RadioGroup @bind-Value="_selected">
    <div class="flex items-start gap-2">
        <RadioItem Id="terms" Value="terms" />
        <div class="flex flex-col gap-1">
            <Label For="terms" Class="font-semibold">Accept terms and conditions</Label>
            <p class="text-sm text-muted-foreground">By selecting this option, you agree to the terms and conditions.</p>
        </div>
    </div>
</RadioGroup>

@code {
    private string? _selected = "terms";
}

