@page "/components/radio-group"

<PageTitle>Radio Group - ShadcnBlazor</PageTitle>
<HeadContent>
    <meta name="description" content="ShadcnBlazor Radio Group - Selection input for choosing one option from multiple choices." />
</HeadContent>
@using System.Reflection
@using ShadcnBlazor.Docs.Pages.Components.Radio.Examples
@using ShadcnBlazor.Docs.Services

<ComponentDocPage Metadata="@Metadata"
                 InstallCommand="@InstallCommand"
                 ApiDoc="@ApiDocumentation.RadioGroup">
    <ComponentPreview DisableHide AllowVerticalScroll InnerClass="max-h-[35vh]" CodeFiles="@(new[] { Snippets.Components_Radio_Examples_RadioBasicExample })">
            <RadioBasicExample />
        </ComponentPreview>

        <FeaturesSection Title="Features" Id="features" Features="@Features" SourceLink="Radio" />

        <DocsSection Title="About" Id="about">
            <p>The <code>RadioGroup</code> component provides single selection within a group. Place <code>RadioItem</code> options inside a <code>RadioGroup</code> and bind <code>Value</code> for the selected option. Pair each item with a <code>Label</code> (or <code>FieldLabel</code>) using matching <code>Id</code> and <code>For</code> attributes.</p>
        </DocsSection>

        <InstallationCommand InstallCommand="@InstallCommand" Metadata="@Metadata" />

    

    <DocsSection Title="Examples" Id="examples">
        <DocsSubSection Title="With Description" Id="with-description">
            <p>Compose labels and helper text next to each item. Use <code>items-start</code> to align the control with the label when descriptions wrap.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Radio_Examples_RadioAlignmentWithDescriptionExample })">
                <RadioAlignmentWithDescriptionExample />
            </ComponentPreview>
        </DocsSubSection>
        <DocsSubSection Title="Fieldset" Id="fieldset">
            <p>Use <code>FieldSet</code> and <code>FieldLegend</code> to provide a group label for the radio items.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Radio_Examples_RadioGroupingExample })">
                <RadioGroupingExample />
            </ComponentPreview>
        </DocsSubSection>
        <DocsSubSection Title="Horizontal" Id="horizontal">
            <p>Set <code>Vertical="false"</code> on RadioGroup to display options horizontally.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Radio_Examples_RadioHorizontalExample })">
                <RadioHorizontalExample />
            </ComponentPreview>
        </DocsSubSection>
        <DocsSubSection Title="Disabled" Id="disabled">
            <p>Use the <code>Disabled</code> parameter on a <code>RadioItem</code> to prevent selecting it, or set <code>Disabled</code> on <code>RadioGroup</code> to disable all options.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Radio_Examples_RadioDisabledExample })">
                <RadioDisabledExample />
            </ComponentPreview>
        </DocsSubSection>
        <DocsSubSection Title="Invalid state" Id="invalid">
            <p>Set <code>Invalid="true"</code> to show the invalid state. The item gets a red border and ring, and the label text can be styled with <code>text-destructive</code>.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Radio_Examples_RadioInvalidExample })">
                <RadioInvalidExample />
            </ComponentPreview>
        </DocsSubSection>
    </DocsSection>
</ComponentDocPage>

@code {
    private static readonly ComponentMetadata Metadata = ComponentRegistryService.GetMetadata("Radio Group");

    private const string InstallCommand = "shadcnblazor component add radio-group";

    private List<RenderFragment> Features => new()
    {
        __builder => { <div>Single selection from grouped options</div> },
        __builder => { <div>Keyboard navigation (arrows support)</div> },
        __builder => { <div>Clear visual state indication for selection</div> },
        __builder => { <div>Seamless integration with RadioGroup container</div> },
    };
}



