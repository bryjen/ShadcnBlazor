<div class="flex flex-col gap-4 border p-6 rounded-md bg-background">
    <div class="flex items-center justify-between">
        <h3 class="text-sm font-semibold">Initial Focus Example</h3>
        <Button Variant="Variant.Outline" Size="Size.Sm" OnClick="@(() => _disabled = !_disabled)">
            @(_disabled ? "Enable Trap" : "Disable Trap")
        </Button>
    </div>

    <FocusTrap Disabled="@_disabled" Options="@_options">
        <div class="flex flex-col gap-4 p-4 border-2 border-dashed border-primary/30 rounded-lg bg-accent/10">
            <p class="text-xs text-muted-foreground">
                When enabled, the focus will automatically land on the <b>Third Input</b> first.
            </p>
            <Input Placeholder="First Input" />
            <Input Placeholder="Second Input" />
            <Input id="focus-me-first" Placeholder="Third Input (Targeted)" />
            <Button>Action Button</Button>
        </div>
    </FocusTrap>
</div>

@code {
    private bool _disabled = true;
    private FocusOptions _options = new() { InitialFocus = "#focus-me-first" };
}
