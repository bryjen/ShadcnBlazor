<div class="flex flex-col gap-6 w-fit">
    <div>
        <p class="text-sm font-medium text-muted-foreground mb-2">CardTitle + CardDescription</p>
        <Card Class="w-[350px]">
            <CardHeader>
                <CardTitle>Card Title</CardTitle>
                <CardDescription>Card description goes here</CardDescription>
            </CardHeader>
            <CardContent>
                <p class="text-sm text-muted-foreground">Main card content.</p>
            </CardContent>
        </Card>
    </div>
    <div>
        <p class="text-sm font-medium text-muted-foreground mb-2">With CardAction</p>
        <Card Class="w-[350px]">
            <CardHeader>
                <div>
                    <CardTitle>Card Title</CardTitle>
                    <CardDescription>With an action in the header</CardDescription>
                </div>
                <CardAction>
                    <Button Variant="@Variant.Ghost" Size="@Size.Sm">×</Button>
                </CardAction>
            </CardHeader>
            <CardContent>
                <p class="text-sm text-muted-foreground">Content below.</p>
            </CardContent>
        </Card>
    </div>
    <div>
        <p class="text-sm font-medium text-muted-foreground mb-2">With CardFooter</p>
        <Card Class="w-[350px]">
            <CardHeader>
                <CardTitle>Card Title</CardTitle>
            </CardHeader>
            <CardContent>
                <p class="text-sm text-muted-foreground">Content area.</p>
            </CardContent>
            <CardFooter Class="justify-between">
                <Button Variant="@Variant.Outline">Cancel</Button>
                <Button Variant="@Variant.Default">Save</Button>
            </CardFooter>
        </Card>
    </div>
</div>
