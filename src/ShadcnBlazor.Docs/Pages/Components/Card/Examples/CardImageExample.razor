<Card Class="w-[350px]">
    <CardHeader Class="!p-0 !space-y-0 !gap-0">
        <img src="https://placehold.co/400x200" alt="Event cover" class="aspect-video w-full object-cover" />
    </CardHeader>
    <CardContent>
        <div class="flex items-start justify-between gap-2">
            <div>
                <CardTitle Class="mt-2">Design systems meetup</CardTitle>
                <CardDescription>A practical talk on component APIs, accessibility, and shipping faster.</CardDescription>
            </div>
            <Badge Variant="@Variant.Secondary">Featured</Badge>
        </div>
    </CardContent>
    <CardFooter>
        <Button Variant="@Variant.Default" Class="w-full">View Event</Button>
    </CardFooter>
</Card>
