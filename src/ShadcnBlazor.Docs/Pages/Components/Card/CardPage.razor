@page "/components/card"

<PageTitle>Card - ShadcnBlazor</PageTitle>
<HeadContent>
    <meta name="description" content="ShadcnBlazor Card - Composable container components for grouping related content." />
</HeadContent>
@using System.Reflection
@using ShadcnBlazor.Docs.Pages.Components.Card.Examples
@using ShadcnBlazor.Docs.Services

<ComponentDocPage Metadata="@Metadata"
                 InstallCommand="@InstallCommand"
                 ApiDoc="@ApiDocumentation.Card">
    <UnderHeader>
        <div class="w-fit">
            <Badge Size="@Size.Md">
                <span class="font-semibold">Composable</span>
            </Badge>
        </div>
    </UnderHeader>

    <ChildContent>
        <FeaturesSection Title="Features" Id="features" Features="@Features" SourceLink="Card" />

        <DocsSection Title="Usage" Id="usage">
            <p class="mb-3">Build cards by composing child components. <code>Card</code> is the container, <code>CardHeader</code>, <code>CardTitle</code>, <code>CardDescription</code>, <code>CardContent</code>, <code>CardFooter</code>, and <code>CardAction</code> are semantic sections you combine as needed.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Card_Examples_CardBasicExample })">
                <CardBasicExample />
            </ComponentPreview>
        </DocsSection>

        <DocsSection Title="Examples" Id="examples">
            <DocsSubSection Title="Card Structure" Id="structure">
                <p class="mb-3">
                    Combine child components to create different card layouts. <code>CardHeader</code> contains <code>CardTitle</code> and <code>CardDescription</code>. <code>CardAction</code> positions content in the top-right of the header. <code>CardContent</code> is the main area, and <code>CardFooter</code> is the bottom section.
                </p>
                <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Card_Examples_CardHeaderFooterExample })">
                    <CardHeaderFooterExample />
                </ComponentPreview>
            </DocsSubSection>

            <DocsSubSection Title="Image Cards" Id="image">
                <p class="mb-3">Use <code>CardHeader</code> with an image and remove padding by adding <code>Class="!p-0"</code> to create edge-to-edge image cards.</p>
                <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Card_Examples_CardImageExample })">
                    <CardImageExample />
                </ComponentPreview>
            </DocsSubSection>

            <DocsSubSection Title="Spacing" Id="spacing">
                <p class="mb-3">Customize spacing by overriding <code>Card</code> and child component classes. Use <code>gap</code> and <code>py</code> on the card, or <code>px</code> and <code>py</code> on sections.</p>
                <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Card_Examples_CardSizeExample })">
                    <CardSizeExample />
                </ComponentPreview>
            </DocsSubSection>

            <DocsSubSection Title="Customization" Id="customization">
                <p class="mb-3">Override default styles with the <code>Class</code> parameter on any component. For example, use <code>Class="!bg-transparent"</code> on <code>Card</code> to remove the background.</p>
                <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Card_Examples_CardVariantExample })">
                    <CardVariantExample />
                </ComponentPreview>
            </DocsSubSection>
        </DocsSection>

        <DocsSection Title="Accessibility" Id="accessibility">
            <p class="mb-3">Card components are semantic containers with no interactive elements. Use proper heading levels: <code>CardTitle</code> should typically be an h2 or h3, never h1. Ensure sufficient color contrast for text and backgrounds (see design tokens).</p>
            <p class="mb-3">When <code>CardAction</code> contains interactive elements like buttons, they are keyboard accessible and focusable by default. Ensure the card's semantic structure aids screen reader users by maintaining proper heading and section hierarchy.</p>
        </DocsSection>
    </ChildContent>
</ComponentDocPage>

@code {
    private static readonly ComponentMetadata Metadata = ComponentRegistryService.GetMetadata("Card");

    private const string InstallCommand = "shadcnblazor component add card";

    private List<RenderFragment> Features => new()
    {
        __builder => { <div>Composable child components for flexible layouts</div> },
        __builder => { <div>CardHeader with CardTitle, CardDescription, and CardAction</div> },
        __builder => { <div>CardContent for main area and CardFooter for bottom section</div> },
        __builder => { <div>Full class customization for spacing, colors, and backgrounds</div> },
        __builder => { <div>Works with images, forms, and interactive content</div> },
    };
}

