@page "/components/switch"

<PageTitle>Switch - ShadcnBlazor</PageTitle>
<HeadContent>
    <meta name="description" content="ShadcnBlazor Switch - Toggle control for boolean on/off states." />
</HeadContent>
@using System.Reflection
@using ShadcnBlazor.Docs.Pages.Components.Switch.Examples
@using ShadcnBlazor.Docs.Services

<ComponentDocPage Metadata="@Metadata"
                 InstallCommand="@InstallCommand"
                 ApiDoc="@ApiDocumentation.Switch">
    <ComponentPreview DisableHide AllowVerticalScroll InnerClass="max-h-[35vh]" CodeFiles="@(new[] { Snippets.Components_Switch_Examples_SwitchBasicExample })">
            <SwitchBasicExample />
        </ComponentPreview>

        <FeaturesSection Title="Features" Id="features" Features="@Features" SourceLink="Switch" />

        <DocsSection Title="About" Id="about">
            <p>The Switch component is a toggle for boolean on/off values. Use <code>ChildContent</code> for the label. Bind <code>Checked</code> for two-way state, or use <code>CheckedChanged</code> for one-way updates.</p>
        </DocsSection>

        <InstallationCommand InstallCommand="@InstallCommand" Metadata="@Metadata" />

    

    <DocsSection Title="Examples" Id="examples">
        <DocsSubSection Title="Sizes" Id="sizes">
            <p>Use the <code>Size</code> parameter for Sm, Md, or Lg variants.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Switch_Examples_SwitchSizeExample })">
                <SwitchSizeExample />
            </ComponentPreview>
        </DocsSubSection>
    </DocsSection>
</ComponentDocPage>

@code {
    private static readonly ComponentMetadata Metadata = ComponentRegistryService.GetMetadata("Switch");

    private const string InstallCommand = "shadcnblazor component add switch";

    private List<RenderFragment> Features => new()
    {
        __builder => { <div>Two-state binary toggling (on/off)</div> },
        __builder => { <div>Smooth visual animation transitions</div> },
        __builder => { <div>Form field integration capabilities</div> },
        __builder => { <div>Keyboard and screen reader support</div> },
    };
}



