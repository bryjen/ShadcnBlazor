@page "/components/badge"

<PageTitle>Badge - ShadcnBlazor</PageTitle>
<HeadContent>
    <meta name="description" content="ShadcnBlazor Badge - Small labels for categorizing content and displaying status indicators." />
</HeadContent>
@using System.Reflection
@using ShadcnBlazor.Docs.Pages.Components.Badge.Examples
@using ShadcnBlazor.Docs.Services

<ComponentDocPage Metadata="@Metadata"
                 InstallCommand="@InstallCommand"
                 ApiDoc="@ApiDocumentation.Badge">

    <ChildContent>
        <ComponentPreview DisableHide AllowVerticalScroll InnerClass="max-h-[35vh]" CodeFiles="@(new[] { Snippets.Components_Badge_Examples_BadgeBasicExample })">
            <BadgeBasicExample />
        </ComponentPreview>

        <FeaturesSection Title="Features" Id="features" Features="@Features" SourceLink="Badge" />

        <DocsSection Title="About" Id="about">
            <p>The Badge component displays small labels or count indicators. Use <code>ChildContent</code> for the label text. Set <code>Variant</code> to <code>default</code>, <code>secondary</code>, <code>destructive</code>, <code>outline</code>, or <code>ghost</code>. Set <code>Size</code> for Sm, Md, or Lg. For semantic badges (status, counts), provide <code>AriaLabel</code> for screen readers.</p>
        </DocsSection>

        <InstallationCommand InstallCommand="@InstallCommand" Metadata="@Metadata" />

    

    <DocsSection Title="Examples" Id="examples">
        <DocsSubSection Title="Variants" Id="variants">
            <p>Use the <code>Variant</code> parameter to change the variant of the badge.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Badge_Examples_BadgeVariantExample })">
                <BadgeVariantExample />
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="With Icon" Id="with-icon">
            <p>You can render an icon inside the badge. Place the icon as the first child for inline-start or as the last child for inline-end.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Badge_Examples_BadgeWithIconExample })">
                <BadgeWithIconExample />
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="With Spinner" Id="with-spinner">
            <p>You can render a spinner inside the badge for loading states. Use <code>LuLoaderCircle</code> with <code>animate-spin</code>.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Badge_Examples_BadgeWithSpinnerExample })">
                <BadgeWithSpinnerExample />
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="Link" Id="link">
            <p>Use the <code>BadgeLink</code> component to render a badge as a link for clickable badges that navigate.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Badge_Examples_BadgeLinkExample })">
                <BadgeLinkExample />
            </ComponentPreview>
        </DocsSubSection>

        <DocsSubSection Title="Custom Colors" Id="custom-colors">
            <p>Customize badge colors by adding custom classes such as <code>bg-green-100 dark:bg-green-900</code> to the <code>Badge</code> component.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Badge_Examples_BadgeCustomColorsExample })">
                <BadgeCustomColorsExample />
            </ComponentPreview>
        </DocsSubSection>
    </DocsSection>

    <DocsSection Title="Accessibility" Id="accessibility">
        <p>For semantic badges (status indicators, counts, or labels), provide <code>AriaLabel</code> to ensure screen readers understand the badge's purpose (e.g., "5 unread messages", "In progress").</p>
        <p>Icon-only badges must have <code>AriaLabel</code>. <code>BadgeLink</code> automatically appends "Opens in new window" to its aria-label when <code>Target="_blank"</code>.</p>
        <p>For purely decorative badges with visible text, <code>AriaLabel</code> is optional.</p>
    </DocsSection>
    </ChildContent>
</ComponentDocPage>

@code {
    private static readonly ComponentMetadata Metadata = ComponentRegistryService.GetMetadata("Badge");

    private const string InstallCommand = "shadcnblazor component add badge";

    private List<RenderFragment> Features => new()
    {
        __builder => { <div>ARIA labels for semantic and icon-only badges</div> },
        __builder => { <div>Automatic "opens in new window" warnings on BadgeLink</div> },
        __builder => { <div>Works with icons and spinners</div> },
        __builder => { <div>BadgeLink provides keyboard and focus support</div> },
    };
}




