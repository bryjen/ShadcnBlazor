@page "/components/accordion"

<PageTitle>Accordion - ShadcnBlazor</PageTitle>
<HeadContent>
    <meta name="description" content="ShadcnBlazor Accordion - Collapsible component for organizing content into expandable panels." />
</HeadContent>
@using System.Reflection
@using ShadcnBlazor.Docs.Pages.Components.Accordion.Examples
@using ShadcnBlazor.Docs.Services

<ComponentDocPage Metadata="@Metadata"
                 InstallCommand="@InstallCommand"
                 ApiDoc="@ApiDocumentation.Accordion">

    <ChildContent>
        <ComponentPreview DisableHide AllowVerticalScroll InnerClass="max-h-[35vh]" CodeFiles="@(new[] { Snippets.Components_Accordion_Examples_AccordionBasicExample })">
            <div class="w-full lg:mx-[clamp(5%,10%,10%)]">
                <AccordionBasicExample/>
            </div>
        </ComponentPreview>

        <FeaturesSection Title="Features" Id="features" Features="@Features" SourceLink="Accordion" />

        <DocsSection Title="About" Id="about">
            <p>The Accordion displays vertically stacked headings that reveal content when clicked. Use <code>AccordionItem</code>, <code>AccordionTrigger</code>, and <code>AccordionContent</code> to build each section. Each item requires a unique <code>Value</code>.</p>
        </DocsSection>

        <InstallationCommand InstallCommand="@InstallCommand" Metadata="@Metadata" />

    

    <DocsSection Title="Examples" Id="examples">
        <DocsSubSection Title="Multiple" Id="multiple">
            <p>Set <code>Type="AccordionType.Multiple"</code> to allow multiple items to be open at the same time. Each item can be toggled independently, and all items can be closed.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Accordion_Examples_AccordionMultipleExample })">
                <div class="w-full lg:mx-[clamp(5%,10%,10%)]">
                    <AccordionMultipleExample />
                </div>
            </ComponentPreview>
        </DocsSubSection>
        <DocsSubSection Title="Collapsible" Id="collapsible">
            <p>By default, clicking an open item closes it. Set <code>Collapsible="false"</code> to require at least one item to remain open—clicking the open item will have no effect.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Accordion_Examples_AccordionCollapsibleExample })">
                <div class="w-full lg:mx-[clamp(5%,10%,10%)]">
                    <AccordionCollapsibleExample />
                </div>
            </ComponentPreview>
        </DocsSubSection>
        <DocsSubSection Title="Disabled" Id="disabled">
            <p>Set <code>Disabled="true"</code> on an <code>AccordionItem</code> to prevent it from being expanded or collapsed. Disabled items appear grayed out and do not respond to clicks.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Accordion_Examples_AccordionDisabledExample })">
                <div class="w-full lg:mx-[clamp(5%,10%,10%)]">
                    <AccordionDisabledExample />
                </div>
            </ComponentPreview>
        </DocsSubSection>
        <DocsSubSection Title="With Card" Id="with-card">
            <p>The Accordion works well inside a <code>Card</code> for FAQ sections, settings panels, or other grouped content.</p>
            <ComponentPreview CodeFiles="@(new[] { Snippets.Components_Accordion_Examples_AccordionCardExample })">
                <div class="w-full lg:mx-[clamp(5%,10%,10%)]">
                    <AccordionCardExample />
                </div>
            </ComponentPreview>
        </DocsSubSection>
    </DocsSection>
    </ChildContent>
</ComponentDocPage>

@code {
    private static readonly ComponentMetadata Metadata = ComponentRegistryService.GetMetadata("Accordion");

    private const string InstallCommand = "shadcnblazor component add accordion";

    private List<RenderFragment> Features => new()
    {
        __builder => { <div>Single or multiple open items</div> },
        __builder => { <div>Controlled and uncontrolled state support</div> },
        __builder => { <div>Optional non-collapsible single mode</div> },
        __builder => { <div>Full keyboard support and ARIA compliance</div> },
        __builder => { <div>Disabled items support</div> },
    };
}




