@page "/forms"

<PageTitle>Forms - ShadcnBlazor</PageTitle>
<HeadContent>
    <meta name="description" content="ShadcnBlazor Forms - Build forms with EditForm, Field, and validation." />
</HeadContent>

<TocPageBase>
<div class="flex flex-col gap-8 min-w-0">
    <div class="flex flex-col gap-1">
        <h1>Forms</h1>
        <p>
            Build forms in Blazor using EditForm.
        </p>
    </div>

    <p>
            Unlike most other component libraries, we do not ship a forms abstraction.
            Rather, we recommend using Blazor's built-in <a href="https://learn.microsoft.com/en-us/aspnet/core/blazor/forms/" target="_blank"><code class="text-[oklch(from_var(--primary)_calc(l_+_0.1)_c_h)] bg-card">EditForm</code></a> component, in tandem with our own <code>&lt;Field/&gt;</code> components.
            This gives full control over forms, allowing vendor-agnostic validation and custom logic on top our styled and accessible components.
        </p>
        <p>
            If you are not familiar with ASP.NET Core's Blazor forms, we provide a brief summary over them.
            Then, we talk about how they integrate with our own <code>&lt;Field/&gt;</code> and <code>&lt;Label/&gt;</code> components to create basic forms.
            Finally, we talk about more "advanced" concepts, such as more advanced field error controls, syntactic sugar, custom validators, etc.
        </p>

    <div class="grid grid-cols-3 gap-6 mt-4">
        <a href="/forms/prerequisites" class="group flex flex-col items-center justify-center p-8 bg-card border border-border rounded-xl hover:bg-card/80 hover:border-border/80 transition-all text-center no-underline"
           @onclick="@(_ => Nav.NavigateTo("/forms/prerequisites"))"
           @onclick:preventDefault="true">
            <div class="mb-6 group-hover:text-foreground transition-colors">
                <svg width="56" height="56" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
                    <path d="M23.8337 8.1013a13.9123 13.9123 0 0 1-13.6424 11.72 10.1053 10.1053 0 0 1-1.994-.121 6.111 6.111 0 0 1-5.0824-5.7607 5.9344 5.9344 0 0 1 11.867-.0838c.025.9835-.4011 1.8464-1.277 1.8713-.9356 0-1.3742-.6677-1.3742-1.5674v-2.5001a1.5313 1.5313 0 0 0-1.5196-1.5328H8.7152a3.6481 3.6481 0 1 0 2.6948 6.0794l.0733-.1093.0734.1213a2.5807 2.5807 0 0 0 2.2007 1.0479 2.9088 2.9088 0 0 0 2.6947-3.0406 7.912 7.912 0 0 0-.217-1.9324 7.4043 7.4043 0 0 0-14.6395 1.6033 7.4971 7.4971 0 0 0 7.307 7.4043s.549.05 1.1677.0357a15.8029 15.8029 0 0 0 8.4747-2.5283c.036-.025.0719.025.048.0614a12.4392 12.4392 0 0 1-9.6901 3.9625A8.7442 8.7442 0 0 1 .003 13.8603a9.049 9.049 0 0 1 3.6349-7.2471 8.8634 8.8634 0 0 1 5.229-1.7262h2.813a7.9145 7.9145 0 0 0 5.8386-2.5777.1093.1093 0 0 1 .0594-.034.1115.1115 0 0 1 .1195.0522.113.113 0 0 1 .0155.0672 7.9345 7.9345 0 0 1-1.2274 3.5493.1075.1075 0 0 0-.0132.0609.1098.1098 0 0 0 .0724.0945.109.109 0 0 0 .0619.0033 8.5054 8.5054 0 0 0 5.9134-4.876.1554.1554 0 0 1 .0546-.0527.1497.1497 0 0 1 .147 0 .1535.1535 0 0 1 .0546.0527 10.779 10.779 0 0 1 1.0575 6.8746zm-14.9383 3.527a2.188 2.188 0 1 0 2.1877 2.1878v-2.0425a.1577.1577 0 0 0-.1497-.1497Z"/>
                </svg>
            </div>
            <div class="flex flex-col">
                <span class="text-lg font-bold tracking-tight leading-tight text-foreground">Prerequisites</span>
                <span class="text-xs font-medium mt-2 text-muted-foreground">Edit Form & Annotations Validator</span>
            </div>
        </a>

        <a href="/forms/basic" class="group flex flex-col items-center justify-center p-8 bg-card border border-border rounded-xl hover:bg-card/80 hover:border-border/80 transition-all text-center no-underline"
           @onclick="@(_ => Nav.NavigateTo("/forms/basic"))"
           @onclick:preventDefault="true">
            <div class="mb-6 group-hover:text-foreground transition-colors">
                <LuBookOpenText class="w-14 h-14" />
            </div>
            <div class="flex flex-col">
                <span class="text-lg font-bold tracking-tight leading-tight text-foreground">Basic Forms</span>
                <span class="text-xs font-medium mt-2 text-muted-foreground">Labels & Field Components</span>
            </div>
        </a>

        <a href="/forms/advanced" class="group flex flex-col items-center justify-center p-8 bg-card border border-border rounded-xl hover:bg-card/80 hover:border-border/80 transition-all text-center no-underline"
           @onclick="@(_ => Nav.NavigateTo("/forms/advanced"))"
           @onclick:preventDefault="true">
            <div class="mb-6 group-hover:foreground transition-colors">
                <LuLayers3 class="w-14 h-14" />
            </div>
            <div class="flex flex-col">
                <span class="text-lg font-bold tracking-tight leading-tight text-foreground">Advanced</span>
                <span class="text-xs font-medium mt-2 text-muted-foreground">Syntactic Sugar, Errors, & 3rd Party Validation</span>
            </div>
        </a>
    </div>
</div>
</TocPageBase>

@code {
    [Inject]
    public required NavigationManager Nav { get; set; }
}



