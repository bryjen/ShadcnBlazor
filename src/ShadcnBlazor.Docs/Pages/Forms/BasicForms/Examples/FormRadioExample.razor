<Field FieldId="visibility" For="() => _visibility">
    <FieldSet>
        <FieldLegend>Visibility</FieldLegend>
        <RadioGroup @bind-Value="_visibility">
            <div class="flex items-center gap-2">
                <RadioItem Id="visibility-public" Value="public" />
                <Label For="visibility-public">Public</Label>
            </div>
            <div class="flex items-center gap-2">
                <RadioItem Id="visibility-private" Value="private" />
                <Label For="visibility-private">Private</Label>
            </div>
        </RadioGroup>
    </FieldSet>
    <FieldError />
</Field>

@code {
    private string _visibility = "public";
}

