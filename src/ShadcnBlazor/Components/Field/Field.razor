@inherits ShadcnComponentBase

<div
    role="group"
    data-slot="field"
    data-invalid="@(IsInvalid ? "true" : null)"
    data-orientation="@Orientation.ToString().ToLower()"
    class="@GetClass()"
    @attributes="AdditionalAttributes">
    <CascadingValue Value="this">
        @ChildContent
    </CascadingValue>
</div>
