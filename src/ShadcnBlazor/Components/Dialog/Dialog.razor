@inherits ShadcnComponentBase

<FocusTrap Disabled="@(State != "open")" @attributes="AdditionalAttributes">
    <div id="@_elementId"
         class="@GetContentClass()"
         data-dialog-content="@Instance.Id.ToString("N")"
         data-state="@State"
         role="dialog"
         aria-modal="true"
         aria-labelledby="@(_hasHeader ? _titleId : null)"
         aria-describedby="@(_hasDescription ? _descriptionId : null)"
         style="@GetDialogStyle()"
         @onclick:stopPropagation>
        @if (_hasHeader)
        {
            <div class="flex flex-row items-start justify-between gap-2 px-6 pt-6">
                <div class="flex-1">
                    <h2 class="text-lg font-semibold leading-normal text-foreground m-0" id="@_titleId">@Instance.Title</h2>
                    @if (_hasDescription)
                    {
                        <p class="text-sm text-muted-foreground mt-1" id="@_descriptionId">@Options.Description</p>
                    }
                </div>
                @if (Options.CloseButton)
                {
                    <button type="button"
                            class="inline-flex items-center justify-center size-8 rounded-md border-none bg-transparent text-muted-foreground cursor-pointer transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-2 focus-visible:outline-ring focus-visible:outline-offset-2"
                            aria-label="Close"
                            @onclick="OnCloseClick">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 6 6 18"></path>
                            <path d="m6 6 12 12"></path>
                        </svg>
                    </button>
                }
            </div>
        }
        @if (Options.Unstyled)
        {
            <CascadingValue TValue="IDialogInstance" Value="_dialogInstance">
                @ChildContent
            </CascadingValue>
        }
        else
        {
            <div class="p-6 overflow-y-auto">
                <CascadingValue TValue="IDialogInstance" Value="_dialogInstance">
                    @ChildContent
                </CascadingValue>
            </div>
        }
    </div>
</FocusTrap>


@code {
    [Parameter]
    public required Models.DialogInstance Instance { get; set; }

    [Parameter]
    public Models.DialogOptions Options { get; set; } = null!;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string State { get; set; } = "closed";

    [Parameter]
    public EventCallback<Models.DialogResult> OnCloseRequested { get; set; }

    private readonly string _elementId = $"dialog-{Guid.NewGuid():N}";
    private readonly string _titleId = $"dialog-title-{Guid.NewGuid():N}";
    private readonly string _descriptionId = $"dialog-description-{Guid.NewGuid():N}";
    private DialogInstanceCascade _dialogInstance = null!;

    private bool _hasHeader => !Options.Unstyled && !Options.NoHeader;
    private bool _hasDescription => _hasHeader && !string.IsNullOrWhiteSpace(Options.Description);

    protected override void OnInitialized()
    {
        _dialogInstance = new DialogInstanceCascade(result => _ = OnCloseRequested.InvokeAsync(result));
    }

    private void OnCloseClick()
    {
        _ = OnCloseRequested.InvokeAsync(Models.DialogResult.Cancel());
    }

    private string GetContentClass()
    {
        if (Options.Unstyled)
        {
            return MergeCss("dialog-unstyled");
        }
        var classes = new List<string> { "dialog-content" };
        if (Options.FullScreen)
        {
            classes.Add("dialog-fullscreen");
        }
        if (Options.FullWidth)
        {
            classes.Add("dialog-fullwidth");
        }
        return MergeCss(string.Join(" ", classes));
    }

    private string GetDialogStyle()
    {
        if (Options.Unstyled)
        {
            return "";
        }
        if (Options.FullScreen)
        {
            return "max-width: none; width: 100vw; height: 100vh;";
        }

        var maxWidth = Options.MaxWidth switch
        {
            Models.DialogMaxWidth.ExtraSmall => "444px",
            Models.DialogMaxWidth.Small => "600px",
            Models.DialogMaxWidth.Medium => "960px",
            Models.DialogMaxWidth.Large => "1280px",
            Models.DialogMaxWidth.ExtraLarge => "1920px",
            _ => "600px"
        };

        return $"max-width: {maxWidth};";
    }
}
