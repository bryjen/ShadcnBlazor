@using ShadcnBlazor.Components.Dialog.Services
@inherits ShadcnComponentBase
@inject DialogInterop DialogInterop

@if (Context?.Open == true)
{
    <div class="dialog-overlay fixed inset-0 z-[1400]"
         data-dialog-overlay="@Context.DialogId"
         data-state="@Context.AnimationState"
         style=""></div>

    <div class="fixed inset-0 z-[1401] flex p-4 overflow-y-auto items-center justify-center"
         @onclick="OnBackdropClick">
        <FocusTrap>
            <div class="@GetContentClass()"
                 data-dialog-content="@Context.DialogId"
                 data-state="@Context.AnimationState"
                 role="dialog"
                 aria-modal="true"
                 style="@GetContentStyle()"
                 @onclick:stopPropagation
                 @attributes="AdditionalAttributes">
                @ChildContent
            </div>
        </FocusTrap>
    </div>
}

@code {
    /// <summary>Dialog content.</summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>Remove default styling. Default: false.</summary>
    [Parameter]
    public bool Unstyled { get; set; } = false;

    [CascadingParameter]
    private DialogContext? Context { get; set; }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Context?.Open != true || Context.DotNetRef == null) return;

        try
        {
            await DialogInterop.InitializeAsync(Context.DialogId, Context.DotNetRef!);
        }
        catch (JSException) { }

        // Yield so browser paints "closed" state before we transition to "open"
        await Task.Delay(50);
        if (Context?.Open == true && !Context.IsClosing && Context.AnimationState == "closed")
        {
            Context.SetAnimationState("open");
            try { await DialogInterop.FocusFirstInDialogAsync(Context.DialogId); }
            catch (JSException) { }
        }
    }

    private async Task OnBackdropClick()
    {
        if (Context?.CloseOnBackdropClick != true) return;
        if (Context.OnClosedByOverlay != null)
            await Context.OnClosedByOverlay();
        _ = Context?.CloseAsync();
    }

    private string GetBaseClass()
    {
        return "relative p-6 w-full border border-border rounded grid gap-0 max-w-[300px]";
    }

    private string GetContentClass()
    {
        if (Unstyled)
            return string.IsNullOrWhiteSpace(Class)
                ? "dialog-unstyled"
                : $"dialog-unstyled {Class}";

        var baseClass = GetBaseClass();
        return string.IsNullOrWhiteSpace(Class)
            ? $"dialog-content {baseClass}"
            : $"dialog-content {baseClass} {Class}";
    }

    private string GetContentStyle()
    {
        if (Unstyled)
            return string.Empty;

        return "background-color: var(--card); color: var(--card-foreground); box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25); border-radius: var(--radius); transition: opacity 200ms cubic-bezier(0.32, 0.72, 0, 1), transform 200ms cubic-bezier(0.32, 0.72, 0, 1);";
    }
}

