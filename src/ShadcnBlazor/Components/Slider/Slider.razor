@inherits ShadcnComponentBase

<div
    id="@_elementId"
    @ref="_containerRef"
    data-slot="slider"
    data-size="@Size.ToString().ToLower()"
    class="@GetContainerClass()"
    @attributes="AdditionalAttributes"
    @onpointermove="OnPointerMove"
    @onpointerup="@(e => OnPointerUp(e))"
    @onpointerleave="@(e => OnPointerUp(e))">

    <!-- Track background (clickable for closest-thumb selection) -->
    <div
        class="pointer-events-auto absolute top-1/2 left-0 right-0 -translate-y-1/2 rounded-full bg-muted cursor-pointer"
        style="@GetTrackStyle()"
        @onpointerdown="OnTrackPointerDown">
    </div>

    <!-- Filled range (from first to last thumb) -->
    <div class="pointer-events-none absolute top-1/2 -translate-y-1/2 rounded-full bg-primary" style="@GetRangeStyle()"></div>

    <!-- Dynamic thumbs -->
    @foreach (var (value, index) in _localValues.Select((v, i) => (v, i)))
    {
        <div
            class="absolute top-1/2 -translate-y-1/2 rounded-full border border-ring bg-white ring-ring/50 cursor-grab active:cursor-grabbing focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
            style="@GetThumbStyle(ToPercent(value))"
            @onpointerdown="@(e => OnThumbPointerDown(index, e))"
            @onkeydown="@(e => OnThumbKeyDown(index, e))"
            role="slider"
            aria-label="@(AriaLabel) @(index + 1)"
            aria-valuemin="@Min"
            aria-valuenow="@value"
            aria-valuemax="@Max"
            tabindex="0">
        </div>
    }
</div>
