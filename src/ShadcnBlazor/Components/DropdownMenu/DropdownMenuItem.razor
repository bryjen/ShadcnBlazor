@inherits ShadcnComponentBase

<button type="button"
        role="menuitem"
        data-inset="@Inset"
        data-variant="@Variant.ToString().ToLower()"
        disabled="@Disabled"
        class="@GetItemClass()"
        @onclick="HandleClick"
        @attributes="AdditionalAttributes">
    @ChildContent
    @if (!string.IsNullOrEmpty(Shortcut))
    {
        <span class="ml-auto text-xs tracking-widest text-muted-foreground">@Shortcut</span>
    }
</button>

@code {
    [CascadingParameter]
    private DropdownMenuContext? Context { get; set; }

    /// <summary>
    /// The menu item content.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Keyboard shortcut to display (e.g., "⌘B").
    /// </summary>
    [Parameter]
    public string? Shortcut { get; set; }

    /// <summary>
    /// When true, the item is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Item variant (default or destructive).
    /// </summary>
    [Parameter]
    public DropdownMenuItemVariant Variant { get; set; } = DropdownMenuItemVariant.Default;

    /// <summary>
    /// When true, adds left padding to accommodate a checkbox/radio indicator.
    /// </summary>
    [Parameter]
    public bool Inset { get; set; }

    /// <summary>
    /// Callback when the item is clicked.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    private string GetItemClass()
    {
        var baseClasses = "relative w-full flex cursor-default items-center gap-2 rounded-sm px-2 py-1.5 text-sm outline-hidden select-none border-0 bg-transparent text-inherit hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 [&_svg:not([class*='text-'])]:text-muted-foreground";

        if (Disabled)
            baseClasses += " pointer-events-none opacity-50";

        if (Inset)
            baseClasses += " pl-8";

        if (Variant == DropdownMenuItemVariant.Destructive)
        {
            baseClasses += " text-destructive hover:bg-destructive/10 hover:text-destructive focus:bg-destructive/10 focus:text-destructive dark:hover:bg-destructive/20 dark:focus:bg-destructive/20 [&_svg]:text-destructive";
        }

        return MergeCss(baseClasses, Class);
    }

    private async Task HandleClick(MouseEventArgs args)
    {
        if (Disabled)
            return;
        await OnClick.InvokeAsync(args);
        Context?.SetOpen?.Invoke(false);
    }
}
