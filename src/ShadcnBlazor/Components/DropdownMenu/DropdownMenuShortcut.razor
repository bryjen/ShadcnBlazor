@inherits ShadcnComponentBase

<span class="@MergeCss("ml-auto text-xs tracking-widest text-muted-foreground", Class)" @attributes="AdditionalAttributes">
    @ChildContent
</span>

@code {
    /// <summary>
    /// The shortcut text (e.g., "⌘+T").
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
