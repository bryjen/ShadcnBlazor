@inherits ShadcnComponentBase

<div role="menuitem"
     tabindex="-1"
     aria-haspopup="menu"
     aria-expanded="@(Context?.Open ?? false)"
     class="@MergeCss("dropdown-menu-item", Context?.Open == true ? "dropdown-menu-sub-trigger-open" : null, Class)"
     @attributes="AdditionalAttributes">
    @ChildContent
    <svg xmlns="http://www.w3.org/2000/svg" class="ml-auto size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m9 18 6-6-6-6"/>
    </svg>
</div>

@code {
    [CascadingParameter]
    private DropdownMenuSubContext? Context { get; set; }

    /// <summary>
    /// The sub-trigger content.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private RenderFragment TriggerFragment => @<div role="menuitem" tabindex="-1" aria-haspopup="menu" aria-expanded="@(Context?.Open ?? false)" class="@MergeCss("dropdown-menu-item", Context?.Open == true ? "dropdown-menu-sub-trigger-open" : null, Class)" @attributes="AdditionalAttributes">
        @ChildContent
        <svg xmlns="http://www.w3.org/2000/svg" class="ml-auto size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6"/>
        </svg>
    </div>;

    protected override void OnInitialized()
    {
        Context?.RegisterTrigger(TriggerFragment);
    }
}
