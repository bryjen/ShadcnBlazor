@using ShadcnBlazor.Services
@inject DrawerService DrawerService

<CascadingValue Value="this" IsFixed="true">
    @ChildContent
</CascadingValue>

@code {
    /// <summary>
    /// The content of the drawer root, containing the trigger and potential overlay/content areas.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>Whether the drawer can be dismissed by clicking outside or dragging.</summary>
    [Parameter]
    public bool Dismissible { get; set; } = true;

    /// <summary>Whether the drawer is modal.</summary>
    [Parameter]
    public bool Modal { get; set; } = true;

    /// <summary>The direction the drawer opens from (top, bottom, left, right).</summary>
    [Parameter]
    public string Direction { get; set; } = "bottom";

    /// <summary>Snap points for the drawer.</summary>
    [Parameter]
    public object[]? SnapPoints { get; set; }

    /// <summary>The active snap point.</summary>
    [Parameter]
    public object? ActiveSnapPoint { get; set; }

    /// <summary>Accessible title for the drawer.</summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>Accessible description for the drawer.</summary>
    [Parameter]
    public string? Description { get; set; }

    /// <summary>Callback invoked when the drawer's open state changes.</summary>
    [Parameter]
    public EventCallback<bool> OnOpenChange { get; set; }

    /// <summary>Callback invoked when the drawer closes.</summary>
    [Parameter]
    public EventCallback OnClose { get; set; }

    private DrawerOverlayOptions? _overlayOptions;
    private DrawerContentOptions? _contentOptions;
    private RenderFragment? _drawerContent;
    private string? _drawerId;

    internal void RegisterOverlay(DrawerOverlayOptions options)
    {
        _overlayOptions = options;
    }

    internal void RegisterContent(DrawerContentOptions options, RenderFragment? content)
    {
        _contentOptions = options;
        _drawerContent = content;
    }

    /// <summary>
    /// Opens the drawer.
    /// </summary>
    public async Task OpenAsync()
    {
        if (_drawerContent == null) return;

        var options = new DrawerOptions
        {
            Drawer = new DrawerOptionsInner
            {
                Dismissible = Dismissible,
                Modal = Modal,
                Direction = Direction,
                SnapPoints = SnapPoints,
                ActiveSnapPoint = ActiveSnapPoint
            },
            Overlay = _overlayOptions ?? new DrawerOverlayOptions
            {
                ClassName = "fixed inset-0 bg-black/40 z-40",
                DisableBaseClass = true
            },
            Content = _contentOptions ?? new DrawerContentOptions
            {
                ClassName = "fixed flex flex-col bg-white border border-gray-200 border-b-none rounded-t-[10px] bottom-0 left-0 right-0 h-full max-h-[97%] mx-[-1px] z-50",
                DisableBaseClass = true
            },
            Title = Title ?? "Drawer",
            Description = Description ?? "Drawer content",
            A11yHidden = true
        };

        var callbacks = new DrawerCallbacks
        {
            OnOpenChange = async open => await OnOpenChange.InvokeAsync(open),
            OnClose = async () =>
            {
                _drawerId = null;
                await OnClose.InvokeAsync();
            }
        };

        _drawerId = await DrawerService.OpenAsync(_drawerContent, options, callbacks);
    }

    /// <summary>
    /// Closes the drawer.
    /// </summary>
    public async Task CloseAsync()
    {
        if (_drawerId != null)
        {
            await DrawerService.CloseAsync(_drawerId);
            _drawerId = null;
        }
    }
}
