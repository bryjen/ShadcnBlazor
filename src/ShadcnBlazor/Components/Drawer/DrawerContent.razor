@using ShadcnBlazor.Services

@code {
    /// <summary>Content to render inside the drawer.</summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>Custom CSS class for the content container.</summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>Whether to disable the default base content class.</summary>
    [Parameter]
    public bool DisableBaseClass { get; set; }

    [CascadingParameter]
    private DrawerRoot? Root { get; set; }

    protected override void OnInitialized()
    {
        Root?.RegisterContent(new DrawerContentOptions
        {
            ClassName = Class,
            DisableBaseClass = DisableBaseClass
        }, ChildContent);
    }

    protected override void OnParametersSet()
    {
        Root?.RegisterContent(new DrawerContentOptions
        {
            ClassName = Class,
            DisableBaseClass = DisableBaseClass
        }, ChildContent);
    }
}
