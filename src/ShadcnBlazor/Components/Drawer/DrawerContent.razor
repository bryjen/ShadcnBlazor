@inherits ShadcnComponentBase
@using ShadcnBlazor.Services
@using ShadcnBlazor.Components.Drawer

@code {
    /// <summary>Content to render inside the drawer.</summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>Whether to disable the default base content class.</summary>
    [Parameter]
    public bool DisableBaseClass { get; set; }

    [CascadingParameter]
    private DrawerRoot? Root { get; set; }

    [CascadingParameter]
    public DrawerDirection Direction { get; set; } = DrawerDirection.Bottom;

    private const string BaseClasses = "bg-popover flex flex-col fixed outline-none z-50";

    private string GetBaseClassForDirection(DrawerDirection direction) => BaseClasses + " " + direction switch
    {
        DrawerDirection.Bottom => "rounded-t-[10px] h-fit bottom-0 left-0 right-0",
        DrawerDirection.Top => "rounded-b-[10px] h-fit top-0 left-0 right-0",
        DrawerDirection.Left => "rounded-r-[10px] w-[35vw] overflow-y-auto overflow-x-hidden scrollbar-hide left-0 top-0 bottom-0",
        DrawerDirection.Right => "rounded-l-[10px] w-[35vw] overflow-y-auto overflow-x-hidden scrollbar-hide right-0 top-0 bottom-0",
        _ => "rounded-t-[10px] h-fit bottom-0 left-0 right-0"
    };

    private string GetFinalClass() => DisableBaseClass ? Class : MergeCss(GetBaseClassForDirection(Direction));

    protected override void OnInitialized()
    {
        Root?.RegisterContent(new DrawerContentOptions
        {
            ClassName = GetFinalClass(),
            DisableBaseClass = true
        }, ChildContent);
    }

    protected override void OnParametersSet()
    {
        Root?.RegisterContent(new DrawerContentOptions
        {
            ClassName = GetFinalClass(),
            DisableBaseClass = true
        }, ChildContent);
    }
}
