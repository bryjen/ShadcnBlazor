@inherits ShadcnComponentBase
@using ShadcnBlazor.Services

@code {
    private const string BaseClass = "bg-popover flex flex-col rounded-t-[10px] h-fit fixed bottom-0 left-0 right-0 outline-none z-50";

    /// <summary>Content to render inside the drawer.</summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>Whether to disable the default base content class.</summary>
    [Parameter]
    public bool DisableBaseClass { get; set; }

    [CascadingParameter]
    private DrawerRoot? Root { get; set; }

    private string GetFinalClass() => DisableBaseClass ? Class : MergeCss(BaseClass);

    protected override void OnInitialized()
    {
        Root?.RegisterContent(new DrawerContentOptions
        {
            ClassName = GetFinalClass(),
            DisableBaseClass = true
        }, ChildContent);
    }

    protected override void OnParametersSet()
    {
        Root?.RegisterContent(new DrawerContentOptions
        {
            ClassName = GetFinalClass(),
            DisableBaseClass = true
        }, ChildContent);
    }
}
